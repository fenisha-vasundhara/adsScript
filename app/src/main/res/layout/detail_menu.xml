<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/_200sdp"
    android:layout_height="@dimen/_50sdp">

    <ImageView
        android:id="@+id/itemNav_img"
        android:layout_width="@dimen/_30sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_height="@dimen/_30sdp"
        android:src="@drawable/dialog_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

     <com.google.android.material.textview.MaterialTextView
        android:id="@+id/itemNav_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_15sdp"
        android:text="jigar dodiya"
        android:textColor="@color/black2"
        android:textSize="@dimen/_15sdp"
        app:layout_constraintBottom_toBottomOf="@+id/itemNav_img"
        app:layout_constraintStart_toEndOf="@+id/itemNav_img"
        app:layout_constraintTop_toTopOf="@+id/itemNav_img" />

</androidx.constraintlayout.widget.ConstraintLayout>