<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_10sdp"
        android:background="@drawable/new_convwesation_dialog_bg">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/message_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/message_txt_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:includeFontPadding="false"
           fullappfontstylesemibold="@{0}"
                android:text="@string/Conversation_List_View"
                android:textColor="@color/black2"
                android:textSize="@dimen/_14sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

             </com.google.android.material.textview.MaterialTextView>


            <Button
                android:layout_width="@dimen/_65sdp"
                android:id="@+id/doneBtn"
                android:layout_height="@dimen/_27sdp"
                android:includeFontPadding="false"
                android:text="@string/Done"
                android:padding="@dimen/_5sdp"
                android:textSize="@dimen/_10sdp"
                app:layout_constraintBottom_toBottomOf="@+id/message_txt_size"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/message_txt_size">

            </Button>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/conversation_Conversation_ListView_archive_btn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/_10sdp"
            android:transitionName="shared_element_transition_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/message_in">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayout15"
                android:layout_width="0dp"
                android:layout_height="@dimen/_90sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginEnd="@dimen/_5sdp"
                android:background="@drawable/list_view_unseleted_item"
                app:layout_constraintEnd_toStartOf="@+id/constraintLayout16"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">


                <ImageView
                    android:id="@+id/two_line_seletion"
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/line_selection_btn"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </ImageView>


                <ImageView
                    android:id="@+id/profile_3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/swipw_profile_new_pf"
                    app:layout_constraintBottom_toTopOf="@+id/profile_4"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toStartOf="@+id/profile_three_line_3"
                    app:layout_constraintHeight_percent="0.3"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </ImageView>

                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line_5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="Alan Walker"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toTopOf="@+id/profile_three_line_3"
                    app:layout_constraintStart_toStartOf="@+id/profile_three_line_3"
                    app:layout_constraintTop_toTopOf="@+id/profile_3"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>

                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_25sdp"
                    android:maxLines="1"
                    android:text="@string/Default_message_1"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toBottomOf="@+id/profile_3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/profile_3"
                    app:layout_constraintTop_toBottomOf="@+id/profile_three_line_5"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>


                <ImageView
                    android:id="@+id/profile_4"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/swipw_profile_new_pf_two"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toStartOf="@+id/profile_three_line_4"
                    app:layout_constraintHeight_percent="0.3"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/profile_3">

                </ImageView>


                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line_6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="Xena"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toTopOf="@+id/profile_three_line_4"
                    app:layout_constraintStart_toStartOf="@+id/profile_three_line_4"
                    app:layout_constraintTop_toTopOf="@+id/profile_4"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>

                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_25sdp"
                    android:maxLines="1"
                    app:layout_constraintTop_toBottomOf="@+id/profile_three_line_6"
                    android:text="@string/Default_message_1"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toBottomOf="@+id/profile_4"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_percent="0.2"
                    app:layout_constraintStart_toEndOf="@+id/profile_4"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>

            </androidx.constraintlayout.widget.ConstraintLayout>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/Two_Lines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_10sdp"
               fullappfontstyleregular="@{0}"
                android:text="@string/Two_Lines"
                android:textColor="@color/black2"
                android:textSize="@dimen/_11sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/constraintLayout15"
                app:layout_constraintStart_toStartOf="@+id/constraintLayout15"
                app:layout_constraintTop_toBottomOf="@+id/constraintLayout15">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/Three_Lines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:fontFamily="@font/rubikregular"
                android:text="@string/Three_Lines"
                android:textColor="@color/black2"
                android:textSize="@dimen/_11sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/constraintLayout16"
                app:layout_constraintStart_toStartOf="@+id/constraintLayout16"
                app:layout_constraintTop_toBottomOf="@+id/constraintLayout16">

             </com.google.android.material.textview.MaterialTextView>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayout16"
                android:layout_width="0dp"
                android:layout_height="@dimen/_90sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginEnd="@dimen/_5sdp"
                android:background="@drawable/list_view_seleted_item"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/constraintLayout15"
                app:layout_constraintTop_toTopOf="parent">


                <ImageView
                    android:id="@+id/three_line_seletion"
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/line_selection_btn"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </ImageView>


                <ImageView
                    android:id="@+id/profile"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/swipw_profile_new_pf"
                    app:layout_constraintBottom_toTopOf="@+id/profile_2"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toStartOf="@+id/profile_three_line"
                    app:layout_constraintHeight_percent="0.3"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </ImageView>

                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line_7"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="Alan Walker"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toTopOf="@+id/profile_three_line"
                    app:layout_constraintStart_toStartOf="@+id/profile_three_line"
                    app:layout_constraintTop_toTopOf="@+id/profile"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>

                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_25sdp"
                    android:maxLines="2"
                    app:layout_constraintTop_toBottomOf="@+id/profile_three_line_7"
                    android:text="@string/Default_message_1"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toBottomOf="@+id/profile"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_percent="0.2"
                    app:layout_constraintStart_toEndOf="@+id/profile"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>


                <ImageView
                    android:id="@+id/profile_2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/swipw_profile_new_pf_two"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toStartOf="@+id/profile_three_line_2"
                    app:layout_constraintHeight_percent="0.3"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/profile">

                </ImageView>


                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line_8"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="Xena"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toTopOf="@+id/profile_three_line_2"
                    app:layout_constraintStart_toStartOf="@+id/profile_three_line_2"
                    app:layout_constraintTop_toTopOf="@+id/profile_2"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>

                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/profile_three_line_2"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toBottomOf="@+id/profile_three_line_8"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_25sdp"
                    android:maxLines="2"
                    android:text="@string/Default_message_1"
                    android:textSize="@dimen/_7sdp"
                    app:layout_constraintBottom_toBottomOf="@+id/profile_2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_percent="0.2"
                    app:layout_constraintStart_toEndOf="@+id/profile_2"
                    app:layout_constraintWidth_percent="0.4">

                 </com.google.android.material.textview.MaterialTextView>

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>