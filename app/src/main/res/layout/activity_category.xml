<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="catAdapter"
            type="com.messenger.phone.number.text.sms.service.apps.adapter.CatAdapter" />

        <variable
            name="isselection"
            type="Boolean" />

        <variable
            name="nomessagefoundchack"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        setchatthemecolorforHomeScreenBg="@{0}"
        android:layout_width="match_parent"


        android:layout_height="match_parent"
        tools:context=".CategoryActivity">


        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/main_menu_ar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tool_bar_main"
                setchatthemecolor="@{0}"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/defaulttoolshow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="@{isselection ? View.GONE : View.VISIBLE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:background="@color/appcolor"
                    tools:visibility="visible"
        android:paddingStart="@dimen/_5sdp"
            android:paddingEnd="@dimen/_5sdp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/back_btn"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="@dimen/mf_appbar_action_size1"
                        app:iconSize="@dimen/mf_appbar_back_icon"    android:layout_height="@dimen/mf_appbar_action_size1"
                        android:layout_marginStart="0dp"
                        app:icon="@drawable/recycle_bin_material_ic_arrow_back_rounded"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="?attr/colorOnSurface"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        />

                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textView3"
                        fullappfontstylesemibold="@{0}"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/mf_appbar_title_spacing"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/Manage_Category"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_18sdp"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="@+id/back_btn"
                        app:layout_constraintEnd_toStartOf="@+id/editmodeon"
                        app:layout_constraintStart_toEndOf="@+id/back_btn"
                        app:layout_constraintTop_toTopOf="@+id/back_btn"
                        tools:visibility="visible">

                     </com.google.android.material.textview.MaterialTextView>

                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/editmodeon"
                        fullappfontstyleregular="@{0}"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/mf_appbar_action_edge_margin"
                        android:text="@string/Edit"
                        android:visibility="gone"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_13sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/textView3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/textView3">

                     </com.google.android.material.textview.MaterialTextView>


                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/selectioncontenar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="@dimen/_5sdp"
                    android:paddingEnd="@dimen/_5sdp"
                    android:visibility="@{isselection ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:visibility="gone">


                    <ImageView
                        android:id="@+id/message_selection_close"
                        android:layout_width="@dimen/mf_appbar_action_size"
                        android:layout_height="@dimen/mf_appbar_action_size"
                        android:layout_marginStart="0dp"
                        android:padding="@dimen/mf_appbar_action_padding"
                        android:src="@drawable/close_icon"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white">

                    </ImageView>

                    <ImageView
                        android:id="@+id/message_delete"
                        android:layout_width="@dimen/mf_appbar_action_size"
                        android:layout_height="@dimen/mf_appbar_action_size"
                        android:layout_marginEnd="@dimen/mf_appbar_action_margin"
                        android:padding="@dimen/mf_appbar_action_padding"
                        android:src="@drawable/baseline_delete_24_black"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/message_edit"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white"
                        tools:visibility="visible">

                    </ImageView>

                    <ImageView
                        android:id="@+id/message_edit"
                        android:layout_width="@dimen/mf_appbar_action_size"
                        android:layout_height="@dimen/mf_appbar_action_size"
                        android:layout_marginEnd="@dimen/mf_appbar_action_edge_margin"
                        android:padding="@dimen/mf_appbar_action_padding"
                        android:src="@drawable/cat_name_edit"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white"
                        tools:visibility="visible">

                    </ImageView>


                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/selectioncount"
                        fullappfontstylesemibold="@{0}"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/mf_appbar_title_spacing"
                        android:layout_marginEnd="@dimen/mf_appbar_title_spacing"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="0 selected"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_18sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/message_selection_close"
                        app:layout_constraintEnd_toStartOf="@+id/message_delete"
                        app:layout_constraintStart_toEndOf="@+id/message_selection_close"
                        app:layout_constraintTop_toTopOf="@+id/message_selection_close">

                     </com.google.android.material.textview.MaterialTextView>


                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.appbar.AppBarLayout>


         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/all_cat"
            fullappfontstyleregular="@{0}"
            setchatthemecolorTintTxtFullapp="@{0}"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:text="@string/All_Categories"
            android:textSize="@dimen/_11sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/main_menu_ar">

         </com.google.android.material.textview.MaterialTextView>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/add_new_cat"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/all_cat">


            <ImageView
                android:id="@+id/imageView30"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/_13sdp"
                android:src="@drawable/con_cat_creat_btn"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.45"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </ImageView>

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_13sdp"
                android:fontFamily="@font/rubikregular"
                android:includeFontPadding="false"
                android:text="@string/Create_Category"
                android:textColor="@color/appcolor"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView30"
                app:layout_constraintTop_toTopOf="parent">

             </com.google.android.material.textview.MaterialTextView>

        </androidx.constraintlayout.widget.ConstraintLayout>


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_10ssp"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/add_new_cat">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bgshow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/con_cat_bg"
                android:paddingStart="@dimen/_10sdp"
                android:paddingTop="@dimen/_2sdp"
                android:paddingEnd="@dimen/_10sdp"
                android:paddingBottom="@dimen/_2sdp"
                app:layout_constraintVertical_bias="0">

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/catlist"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:adapter="@{catAdapter}"
                        android:nestedScrollingEnabled="true"
                        android:orientation="vertical"
                        android:visibility="visible"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:itemCount="5"
                        tools:listitem="@layout/participants_mobile_list">

                    </androidx.recyclerview.widget.RecyclerView>

                </androidx.core.widget.NestedScrollView>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
