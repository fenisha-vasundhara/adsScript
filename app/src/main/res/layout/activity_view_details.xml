<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="isLetterorNot"
            type="Boolean" />

        <variable
            name="notreplychack"
            type="Boolean" />

        <variable
            name="textsizechagefor10"
            type="Float" />

        <variable
            name="textsizechagefor13"
            type="Float" />

        <variable
            name="textsizechagefor18"
            type="Float" />

        <variable
            name="textsizechagefor8"
            type="Float" />

        <variable
            name="textsizechagefor15"
            type="Float" />


        <variable
            name="adapter"
            type="com.messenger.phone.number.text.sms.service.apps.adapter.ParticipantsmobileAdaper" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".ViewDetailsActivity">


        <LinearLayout
            android:id="@+id/vAnd15StatusBar"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/white"
            android:orientation="vertical"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/defaulttoolshow"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@color/white"
            android:paddingStart="@dimen/_5sdp"
            android:paddingEnd="@dimen/_5sdp"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/vAnd15StatusBar"
            tools:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/back_btn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="@dimen/mf_appbar_action_size1"
                android:layout_height="@dimen/mf_appbar_action_size1"
                android:layout_marginStart="0dp"
                app:iconSize="@dimen/mf_appbar_back_icon"     android:contentDescription="@string/cd_back"
                app:icon="@drawable/recycle_bin_material_ic_arrow_back_rounded"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/black"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textView3"

                fullappfontstylesemibold="@{0}"
                setTextSizeFullApp="@{textsizechagefor18}"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/mf_appbar_title_spacing"
                android:text="@string/View_Details"
                android:textColor="@color/black"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@+id/back_btn"
                app:layout_constraintStart_toEndOf="@+id/back_btn"
                app:layout_constraintTop_toTopOf="@+id/back_btn"
                tools:visibility="visible">

            </com.google.android.material.textview.MaterialTextView>


        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.core.widget.NestedScrollView
            android:id="@+id/nest"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:paddingStart="@dimen/_10sdp"
            android:paddingEnd="@dimen/_10sdp"
            app:layout_constraintBottom_toTopOf="@+id/constSmallNativeAdView"
            app:layout_constraintTop_toBottomOf="@+id/defaulttoolshow">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/icon_contact"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.29">

                    <ImageView
                        android:id="@+id/user_profile_image"
                        ColorChangeImgeTint="@{0}"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/icon_round_shap"
                        android:visibility="gone"
                        app:cardElevation="3dp"
                        app:cardUseCompatPadding="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">


                    </ImageView>


                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/numberfisttxt"
                        setTextSizeFullApp="@{textsizechagefor18}"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="@{isLetterorNot ? View.VISIBLE : View.GONE}"
                        app:layout_constraintBottom_toBottomOf="@+id/user_profile_image"
                        app:layout_constraintEnd_toEndOf="@+id/user_profile_image"
                        app:layout_constraintStart_toStartOf="@+id/user_profile_image"
                        app:layout_constraintTop_toTopOf="@+id/user_profile_image"
                        tools:text="J">

                    </com.google.android.material.textview.MaterialTextView>

                    <ImageView
                        android:id="@+id/contacticon"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/contacticon"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                    </ImageView>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/username"
                    fullappfontstylesemibold="@{0}"
                    setTextSizeFullApp="@{textsizechagefor15}"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_20sdp"
                    android:layout_marginTop="@dimen/_13sdp"
                    android:layout_marginEnd="@dimen/_20sdp"
                    android:ellipsize="marquee"
                    android:fadingEdge="horizontal"
                    android:gravity="center"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:scrollHorizontally="true"
                    android:singleLine="true"
                    android:text="Jigar Dodiya"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/icon_contact">

                </com.google.android.material.textview.MaterialTextView>

                <LinearLayout
                    android:id="@+id/constraintLayout4"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:gravity="center"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_20sdp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/username">


                    <LinearLayout
                        android:id="@+id/call_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_15sdp"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/sms_btn"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/imageView4"
                            android:layout_width="@dimen/_25sdp"
                            android:layout_height="@dimen/_25sdp"
                            android:src="@drawable/view_details_material_ic_call_outlined"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>


                        <com.google.android.material.textview.MaterialTextView
                            fullappfontstyleregular="@{0}"
                            android:textSize="@dimen/_9ssp"

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:ellipsize="marquee"
                            android:gravity="start"
                            android:singleLine="true"
                            android:text="@string/Call"
                            android:id="@+id/txtButtonCall"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView4"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/imageView4"
                            app:layout_constraintTop_toTopOf="@+id/imageView4">

                        </com.google.android.material.textview.MaterialTextView>

                    </LinearLayout>


                    <View
                        android:id="@+id/btnDivider1"
                        android:layout_width="@dimen/_1sdp"
                        android:layout_marginVertical="@dimen/_15sdp"
                        android:layout_height="match_parent"/>

                    <LinearLayout

                        android:id="@+id/sms_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"

                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_15sdp"
                        android:paddingHorizontal="@dimen/_10sdp"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/wp_btn1"
                        app:layout_constraintStart_toEndOf="@+id/call_btn"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/imageView5"
                            android:layout_width="@dimen/_25sdp"
                            android:layout_height="@dimen/_25sdp"
                            android:src="@drawable/baseline_archive_24"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>


                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtButtonArchive"
                            fullappfontstyleregular="@{0}"
                            android:textSize="@dimen/_9ssp"
                            android:layout_width="wrap_content"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:gravity="start"


                            android:singleLine="true"
                            android:text="@string/Archive"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView5"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0"
                            app:layout_constraintStart_toEndOf="@+id/imageView5"
                            app:layout_constraintTop_toTopOf="@+id/imageView5">

                        </com.google.android.material.textview.MaterialTextView>

                    </LinearLayout>

                    <View
                        android:id="@+id/btnDivider11"
                        android:layout_width="@dimen/_1sdp"
                        android:layout_marginVertical="@dimen/_15sdp"
                        android:layout_height="match_parent"/>

                    <LinearLayout

                        android:id="@+id/wp_btn1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"

                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_15sdp"
                        android:paddingHorizontal="@dimen/_10sdp"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/delete_btn"
                        app:layout_constraintStart_toEndOf="@+id/sms_btn"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/imageView51"
                            android:layout_width="@dimen/_25sdp"
                            android:layout_height="@dimen/_25sdp"
                            android:src="@drawable/ic_wp_view_detail"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>


                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtButtonWp"
                            fullappfontstyleregular="@{0}"
                            android:textSize="@dimen/_9ssp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:ellipsize="marquee"
                            android:gravity="start"


                            android:singleLine="true"
                            android:text="@string/whatsapp"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView51"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0"
                            app:layout_constraintStart_toEndOf="@+id/imageView51"
                            app:layout_constraintTop_toTopOf="@+id/imageView51">

                        </com.google.android.material.textview.MaterialTextView>

                    </LinearLayout>




                    <View
                        android:id="@+id/btnDivider2"
                        android:layout_width="@dimen/_1sdp"
                        android:layout_marginVertical="@dimen/_15sdp"
                        android:layout_height="match_parent"/>

                    <LinearLayout
                        android:id="@+id/delete_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_15sdp"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/sms_btn"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/imageView6"
                            android:layout_width="@dimen/_25sdp"
                            android:layout_height="@dimen/_25sdp"
                            android:src="@drawable/baseline_person_add_alt_24"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>


                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtButtonAdd"
                            fullappfontstyleregular="@{0}"
                            android:textSize="@dimen/_9ssp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:ellipsize="marquee"
                            android:gravity="start"
                            android:text="@string/Add_to_contact_new_ui"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView6"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0"
                            app:layout_constraintStart_toEndOf="@+id/imageView6"
                            app:layout_constraintTop_toTopOf="@+id/imageView6">

                        </com.google.android.material.textview.MaterialTextView>

                    </LinearLayout>


                </LinearLayout>


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/constraintLayout6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_percent="0.30"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/constraintLayout4">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textView6"
                        fullappfontstyleregular="@{0}"
                        setTextSizeFullApp="@{textsizechagefor15}"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/opensansregular"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:text="@string/More_Info"
                        android:textColor="@color/black"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                    </com.google.android.material.textview.MaterialTextView>



                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/line1"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="@dimen/_15sdp"
                        app:layout_constraintBottom_toTopOf="@+id/show_notification"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="1.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/textView6">

                        <ImageView
                            android:id="@+id/imageView7"
                            android:layout_width="@dimen/_21sdp"
                            android:layout_height="@dimen/_21sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/view_details_material_ic_call_outlined"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mobilenumbertxt"
                            fullappfontstyleregular="@{0}"
                            setTextSizeFullApp="@{textsizechagefor13}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:layout_marginEnd="@dimen/_15sdp"
                            android:ellipsize="marquee"
                            android:fadingEdge="horizontal"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:text="+919664766997"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView7"
                            app:layout_constraintEnd_toStartOf="@+id/number_copy_btn"
                            app:layout_constraintStart_toEndOf="@+id/imageView7"
                            app:layout_constraintTop_toTopOf="@+id/imageView7">

                        </com.google.android.material.textview.MaterialTextView>

                        <ImageView
                            android:id="@+id/number_copy_btn"
                            android:layout_width="@dimen/_21sdp"
                            android:layout_height="@dimen/_21sdp"
                            android:layout_marginEnd="20dp"
                            android:background="@drawable/ripple_custom_circle"
                            android:contentDescription="@string/cd_copy_number"
                            android:src="@drawable/view_details_material_ic_content_copy_outlined"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView7"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHeight_percent="0.45"
                            app:layout_constraintTop_toTopOf="@+id/imageView7"
                            app:tint="@color/grey">

                        </ImageView>

                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/show_notification"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toTopOf="@+id/custom_notification"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/line1">

                        <ImageView
                            android:id="@+id/notification_chat"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/view_details_material_ic_notifications_outlined"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.45"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textView8"
                            fullappfontstyleregular="@{0}"
                            setTextSizeFullApp="@{textsizechagefor13}"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:text="@string/Show_Notication"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/notification_chat"
                            app:layout_constraintTop_toTopOf="parent">

                        </com.google.android.material.textview.MaterialTextView>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/notification_get_or_not"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:checked="true"
                            android:scaleX="0.7"
                            android:scaleY="0.7"
                            android:visibility="visible"
                            app:layout_constraintBottom_toBottomOf="@+id/textView8"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/textView8" />


                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/custom_notification"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:visibility="visible"
                        app:layout_constraintBottom_toTopOf="@+id/contact_Private_chat"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/show_notification">

                        <ImageView
                            android:id="@+id/custom_notification_image"
                            android:layout_width="@dimen/_21sdp"
                            android:layout_height="@dimen/_21sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/view_details_material_ic_notifications_outlined"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.45"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/custom_notification_txt"
                            fullappfontstyleregular="@{0}"
                            setTextSizeFullApp="@{textsizechagefor13}"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:text="@string/custom_Notication"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/custom_notification_image"
                            app:layout_constraintTop_toTopOf="parent">

                        </com.google.android.material.textview.MaterialTextView>


                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/contact_Private_chat"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        app:layout_constraintBottom_toTopOf="@+id/contact_archive"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/custom_notification">

                        <ImageView
                            android:id="@+id/imageView8Private_chat"
                            android:layout_width="@dimen/_21sdp"
                            android:layout_height="@dimen/_21sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/view_details_material_ic_lock_outlined"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.45"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/archiveornotPrivate_chat"
                            fullappfontstyleregular="@{0}"
                            setTextSizeFullApp="@{textsizechagefor13}"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:text="@string/Move_to_Private_new"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView8Private_chat"
                            app:layout_constraintStart_toEndOf="@+id/imageView8Private_chat"
                            app:layout_constraintTop_toTopOf="@+id/imageView8Private_chat">

                        </com.google.android.material.textview.MaterialTextView>

                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/contact_archive"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        app:layout_constraintBottom_toTopOf="@+id/block_number_btn"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/contact_Private_chat">

                        <ImageView
                            android:id="@+id/imageView8"
                            android:layout_width="@dimen/_21sdp"
                            android:layout_height="@dimen/_21sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/view_details_material_ic_delete_outlined"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.45"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/grey">

                        </ImageView>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/archiveornot"
                            fullappfontstyleregular="@{0}"
                            setTextSizeFullApp="@{textsizechagefor13}"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:text="@string/clear_conversation"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView8"
                            app:layout_constraintStart_toEndOf="@+id/imageView8"
                            app:layout_constraintTop_toTopOf="@+id/imageView8">

                        </com.google.android.material.textview.MaterialTextView>

                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/block_number_btn"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/contact_archive">

                        <ImageView
                            android:id="@+id/imageView9"
                            android:layout_width="@dimen/_21sdp"
                            android:layout_height="@dimen/_21sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/view_details_material_ic_block_outlined"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.45"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/red">

                        </ImageView>


                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtnumberblockornot"
                            fullappfontstyleregular="@{0}"
                            setTextSizeFullApp="@{textsizechagefor13}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:layout_marginEnd="@dimen/_20sdp"
                            android:ellipsize="marquee"
                            android:fadingEdge="horizontal"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:text="@string/Block"
                            android:textColor="@color/red"
                            app:layout_constraintBottom_toBottomOf="@+id/imageView9"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/imageView9"
                            app:layout_constraintTop_toTopOf="@+id/imageView9">

                        </com.google.android.material.textview.MaterialTextView>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/participants_mobile_number"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:layout_marginEnd="@dimen/_15sdp"
                    android:layout_marginBottom="@dimen/_20sdp"
                    android:background="@color/white"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_percent="0.30"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/constraintLayout6"
                    tools:visibility="visible">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textView6_new"
                        fullappfontstyleregular="@{0}"
                        setTextSizeFullApp="@{textsizechagefor13}"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="@string/Contact_info"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                    </com.google.android.material.textview.MaterialTextView>


                    <View
                        android:id="@+id/view3_new"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:background="@color/grey"
                        app:layout_constraintTop_toBottomOf="@+id/textView6_new">

                    </View>


                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/participants_mobile_numberlist"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:adapter="@{adapter}"
                        android:orientation="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/view3_new"
                        tools:listitem="@layout/participants_mobile_list">


                    </androidx.recyclerview.widget.RecyclerView>


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.core.widget.NestedScrollView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constSmallNativeAdView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent">


            <FrameLayout
                android:id="@+id/frameSmallNativeAdBottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </FrameLayout>

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/smallNativeAdShimmerBottom"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginHorizontal="@dimen/_1sdp"
                android:layout_marginVertical="@dimen/_2sdp"
                android:elevation="@dimen/_2sdp"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="parent"
                app:shimmer_auto_start="true"
                app:shimmer_duration="800"
                app:shimmer_fixed_width="@dimen/_160sdp"
                app:shimmer_highlight_color="@color/white"
                tools:layout_editor_absoluteX="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
