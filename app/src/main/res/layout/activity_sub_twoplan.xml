<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewmodel"
            type="com.demo.adsmanage.viewmodel.SubActivityTwoplanViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/newsubbg"
        tools:context=".Activity.SubActivityTwoplanActivity">

        <LinearLayout
            android:id="@+id/vAnd15StatusBar"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="vertical"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <ImageView
            android:id="@+id/close_icon"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:visibility="invisible"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:src="@drawable/close_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/vAnd15StatusBar">

        </ImageView>

         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvFancy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sfprodisplaybold"
            android:gravity="center"
            android:shadowColor="#888888"
            android:shadowDx="3"
             android:layout_marginTop="@dimen/_15sdp"
            android:shadowDy="3"
            android:shadowRadius="5"
            android:text="UPGRADE &amp; CHAT\nWithout  Limits!"
            android:textColor="#000000"
            android:textSize="@dimen/_20sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="@id/close_icon"
           >

         </com.google.android.material.textview.MaterialTextView>

        <LinearLayout
            android:id="@+id/linearLayout2"
            android:layout_width="@dimen/_150sdp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"

            android:background="@drawable/one_bg_paywall"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvFancy">

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/_6sdp"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false"
                android:maxLength="10"
                android:text="@string/hey_there"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp">

             </com.google.android.material.textview.MaterialTextView>

            <ImageView
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:src="@drawable/waw_img">

            </ImageView>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout5"
            android:layout_width="@dimen/_100sdp"
            android:layout_height="wrap_content"
            android:background="@drawable/two_bg_paywall"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/linearLayout6"
            app:layout_constraintEnd_toStartOf="@+id/linearLayout6"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/linearLayout6">

            <ImageView
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:src="@drawable/one_pay">

            </ImageView>

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false"
                android:maxLength="6"
                android:singleLine="true"
                android:text="@string/no_ads_1"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp">

             </com.google.android.material.textview.MaterialTextView>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout6"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout8"
            android:layout_width="@dimen/_170sdp"
            android:layout_height="wrap_content"
            android:background="@drawable/three_bg_paywall"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/linearLayout5"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout2">


            <ImageView
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:src="@drawable/two_pay">

            </ImageView>

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false"
                android:maxLength="16"
                android:singleLine="true"
                android:text="@string/backup_amp_restore"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp">

             </com.google.android.material.textview.MaterialTextView>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout7"
            android:layout_width="@dimen/_130sdp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10sdp"
            android:background="@drawable/four_bg_paywall"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/linearLayout8"
            app:layout_constraintEnd_toStartOf="@+id/linearLayout8"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/linearLayout8">


            <ImageView
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:src="@drawable/three_pay">

            </ImageView>

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false"
                android:maxLength="11"
                android:singleLine="true"
                android:text="@string/secure_chat"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp">

             </com.google.android.material.textview.MaterialTextView>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout8"
            android:layout_width="@dimen/_180sdp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/con"
            android:layout_marginEnd="@dimen/_10sdp"
            android:background="@drawable/five_bg_paywall"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/linearLayout7"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout6">


            <ImageView
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:src="@drawable/four_pay">

            </ImageView>

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginBottom="@dimen/_6sdp"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false"
                android:maxLength="13"
                android:singleLine="true"
                android:text="@string/customization"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp">

             </com.google.android.material.textview.MaterialTextView>

        </LinearLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/con"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/new_pay_wall_rating_bg"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/_10sdp"
            app:layout_constraintBottom_toTopOf="@+id/mCLLIFELayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.503"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/imageView16"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_15sdp"
                android:src="@drawable/pan_one"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </ImageView>


            <ImageView
                android:id="@+id/imageView18"
                android:layout_width="@dimen/_80sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:src="@drawable/pan_star"
                app:layout_constraintBottom_toTopOf="@+id/onem"
                app:layout_constraintStart_toEndOf="@+id/imageView16"
                app:layout_constraintTop_toTopOf="@+id/imageView16"
                app:layout_constraintVertical_chainStyle="packed">

            </ImageView>


            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/onem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_3sdp"
                android:paddingHorizontal="@dimen/_30sdp"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:gravity="center"
                android:text="@string/by_1m_users"
                android:textColor="@color/black2"
                android:textSize="@dimen/_14sdp"
                app:layout_constraintBottom_toBottomOf="@+id/imageView16"
                app:layout_constraintEnd_toEndOf="@+id/imageView29"
                app:layout_constraintStart_toStartOf="@+id/imageView16"
                app:layout_constraintTop_toBottomOf="@+id/imageView18">

            </com.google.android.material.textview.MaterialTextView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textView19"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:fontFamily="@font/poppins_semibold"
                android:includeFontPadding="false"
                android:paddingTop="@dimen/_4sdp"
                android:paddingEnd="@dimen/_5sdp"
                android:text="4.8/5"
                android:textColor="@color/black2"
                android:textSize="@dimen/_14sdp"
                app:layout_constraintBottom_toBottomOf="@+id/imageView18"
                app:layout_constraintStart_toEndOf="@+id/imageView18"
                app:layout_constraintTop_toTopOf="@+id/imageView18">

            </com.google.android.material.textview.MaterialTextView>


            <ImageView
                android:id="@+id/imageView29"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_15sdp"
                android:src="@drawable/pan_two"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/textView19"
                app:layout_constraintTop_toTopOf="parent">

            </ImageView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mCLLIFELayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintHeight_percent="0.125"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:background="@drawable/unselection_bg"
            app:layout_constraintBottom_toTopOf="@+id/mCLWeekLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintVertical_chainStyle="packed">

            <ImageView
                android:id="@+id/imageView19"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_20sdp"
                android:src="@drawable/lifetime_pro_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </ImageView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/life"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_bold"
                android:text="@string/lifetime_plan"
                android:textSize="@dimen/_13sdp"
                android:layout_marginStart="@dimen/_10sdp"
                android:textColor="@color/black2"
                app:layout_constraintBottom_toTopOf="@+id/one_time"
                app:layout_constraintStart_toEndOf="@+id/imageView19"
                app:layout_constraintTop_toTopOf="@+id/imageView19"
                app:layout_constraintVertical_chainStyle="packed">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/one_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_regular"
                android:text="@string/one_time_payment"
                android:layout_marginTop="@dimen/_4sdp"
                android:textSize="@dimen/_11sdp"
                android:textColor="#ABAEB3"
                app:layout_constraintBottom_toBottomOf="@+id/imageView19"
                app:layout_constraintStart_toStartOf="@+id/life"
                app:layout_constraintTop_toBottomOf="@+id/life">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtlifePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_bold"
                android:text="₹499"
                android:textSize="@dimen/_16sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:textColor="@color/black2"
                app:layout_constraintBottom_toBottomOf="@+id/life"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/life">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtlifediscountid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_regular"
                android:text="₹2499"
                android:textSize="@dimen/_11sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:textColor="#ABAEB3"
                app:layout_constraintBottom_toBottomOf="@+id/one_time"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/life">

             </com.google.android.material.textview.MaterialTextView>


        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mCLWeekLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:background="@drawable/selection_bg"
            app:layout_constraintBottom_toTopOf="@+id/mCLUnlockLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.125"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/imageView20"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_20sdp"
                android:src="@drawable/week_pro_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </ImageView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:fontFamily="@font/lato_bold"
                android:text="@string/weekly_plan"
                android:textColor="@color/black2"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintBottom_toTopOf="@+id/grete_time"
                app:layout_constraintStart_toEndOf="@+id/imageView20"
                app:layout_constraintTop_toTopOf="@+id/imageView20"
                app:layout_constraintVertical_chainStyle="packed">

            </com.google.android.material.textview.MaterialTextView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/grete_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_regular"
                android:singleLine="true"
                android:paddingEnd="@dimen/_2sdp"
                android:text="@string/great_for_short_term_use"
                android:textColor="#ABAEB3"
                android:textAlignment="viewStart"
                app:layout_constraintBottom_toBottomOf="@+id/imageView20"
                app:layout_constraintEnd_toStartOf="@+id/week_price_main"
                app:layout_constraintStart_toStartOf="@+id/week"
                app:layout_constraintTop_toBottomOf="@+id/week">

            </com.google.android.material.textview.MaterialTextView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtweekPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_15sdp"
                android:fontFamily="@font/lato_bold"
                android:text="₹99"
                android:textColor="@color/black2"
                android:textSize="@dimen/_16sdp"
                app:layout_constraintBottom_toBottomOf="@+id/week"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/week">

            </com.google.android.material.textview.MaterialTextView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/week_price_main"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_15sdp"
                android:fontFamily="@font/lato_regular"
                android:text="@string/week"
                android:textColor="#ABAEB3"
                app:layout_constraintBottom_toBottomOf="@+id/grete_time"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/week">

            </com.google.android.material.textview.MaterialTextView>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/mCLUnlockLayout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_65sdp"
            android:background="@drawable/paywall_btn"
            android:gravity="center"
            app:layout_constraintBottom_toTopOf="@+id/sectxt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
           >

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:id="@+id/txt_unlock_kriadl"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/_4sdp"
                android:fontFamily="@font/lato_bold"
                android:includeFontPadding="false"
                android:text="Continue &amp; Unlock Premium"
                android:textColor="@color/white"
                android:textSize="@dimen/_15sdp">

             </com.google.android.material.textview.MaterialTextView>

        </LinearLayout>


        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/sectxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_regular"
            android:gravity="center"
            android:includeFontPadding="false"
            android:layout_marginVertical="@dimen/_5sdp"
            android:lines="1"
            android:paddingHorizontal="@dimen/_20sdp"
            android:text="@string/secure_purchase_cancel_anytime"
            android:textColor="#464444"
            android:textSize="@dimen/_12sdp"
            app:layout_constraintBottom_toTopOf="@+id/txtTerms"
            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtPrivacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_20sdp"
            android:fontFamily="@font/lato_regular"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lines="1"
            android:text="@string/PrivacyPolicyNew"
            android:textColor="#191919"
            android:textSize="@dimen/_11sdp"
            app:layout_constraintBottom_toBottomOf="@+id/txtTerms"
            app:layout_constraintStart_toStartOf="parent" />

         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtTerms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_20sdp"
             android:layout_marginVertical="@dimen/_10sdp"
             android:fontFamily="@font/lato_regular"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lines="1"
            android:text="@string/user_agreement"
            android:textColor="#191919"
            android:textSize="@dimen/_11sdp"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintBottom_toBottomOf="parent"
             />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
