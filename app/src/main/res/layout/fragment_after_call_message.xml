<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        setchatthemecolorforHomeScreenBg="@{0}"


        android:layout_height="match_parent"
        tools:context=".AfterCallScreen.fragment.AfterCallMessageFragment">


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.cardview.widget.CardView
                    android:id="@+id/after_call_direct_message_one"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_15sdp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/ans_one"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/checkBox1"
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/aftercallcheckbox"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/appcolor">

                        </ImageView>


                         <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/ans_one_txt"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:singleLine="true"
                            android:text="@string/sorry_i_can_t_talk_right_now"
                            android:textSize="@dimen/_12sdp"
                            setchatthemecolorTintTxt="@{0}"
                            app:layout_constraintBottom_toBottomOf="@+id/checkBox1"
                            app:layout_constraintEnd_toStartOf="@+id/ans_one_send"
                            app:layout_constraintStart_toEndOf="@+id/checkBox1"
                            app:layout_constraintTop_toTopOf="@+id/checkBox1">

                         </com.google.android.material.textview.MaterialTextView>

                        <ImageView
                            android:id="@+id/ans_one_send"
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:layout_marginEnd="@dimen/_12sdp"
                            android:src="@drawable/baseline_send_24"
                            app:layout_constraintBottom_toBottomOf="@+id/ans_one_txt"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/ans_one_txt"
                            app:tint="@color/appcolor">

                        </ImageView>


                    </androidx.constraintlayout.widget.ConstraintLayout>


                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/after_call_direct_message_two"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_15sdp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/after_call_direct_message_one">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/ans_two"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/checkBox2"
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/aftercallring"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/appcolor">

                        </ImageView>


                         <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/ans_two_txt"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:singleLine="true"
                            android:text="@string/can_i_call_you_later"
                            android:textSize="@dimen/_12sdp"
                            setchatthemecolorTintTxt="@{0}"
                            app:layout_constraintBottom_toBottomOf="@+id/checkBox2"
                            app:layout_constraintEnd_toStartOf="@+id/ans_two_txt_send"
                            app:layout_constraintStart_toEndOf="@+id/checkBox2"
                            app:layout_constraintTop_toTopOf="@+id/checkBox2">

                         </com.google.android.material.textview.MaterialTextView>

                        <ImageView
                            android:id="@+id/ans_two_txt_send"
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_marginEnd="@dimen/_12sdp"
                            android:src="@drawable/baseline_send_24"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="@+id/ans_two_txt"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/ans_two_txt"
                            app:tint="@color/appcolor">

                        </ImageView>


                    </androidx.constraintlayout.widget.ConstraintLayout>


                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/after_call_direct_message_three"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_15sdp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/after_call_direct_message_two">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/ans_three"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/checkBox3"
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/aftercallring"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/appcolor">

                        </ImageView>


                         <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/ans_three_txt"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:singleLine="true"
                            android:text="@string/i_m_on_my_way"
                            android:textSize="@dimen/_12sdp"
                            setchatthemecolorTintTxt="@{0}"
                            app:layout_constraintBottom_toBottomOf="@+id/checkBox3"
                            app:layout_constraintEnd_toStartOf="@+id/ans_three_txt_send"
                            app:layout_constraintStart_toEndOf="@+id/checkBox3"
                            app:layout_constraintTop_toTopOf="@+id/checkBox3">

                         </com.google.android.material.textview.MaterialTextView>

                        <ImageView
                            android:id="@+id/ans_three_txt_send"
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_marginEnd="@dimen/_12sdp"
                            android:src="@drawable/baseline_send_24"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="@+id/ans_three_txt"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/ans_three_txt"
                            app:tint="@color/appcolor">

                        </ImageView>


                    </androidx.constraintlayout.widget.ConstraintLayout>


                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/after_call_direct_message_custome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_15sdp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/after_call_direct_message_three">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/ans_custome"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/send_img"
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:layout_marginStart="@dimen/_20sdp"
                            android:src="@drawable/baseline_edit_24"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/appcolor">

                        </ImageView>


                        <EditText
                            android:id="@+id/ans_three_edit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:background="@android:color/transparent"
                            android:hint="@string/write_personal_message"
                            android:textColorHint="#87A0B7"
                            android:singleLine="true"
                            setchatthemecolorTintTxt="@{0}"
                            android:textSize="@dimen/_12sdp"
                            app:layout_constraintBottom_toBottomOf="@+id/send_img"
                            app:layout_constraintEnd_toStartOf="@+id/ans_custome_txt_send"
                            app:layout_constraintStart_toEndOf="@+id/send_img"
                            app:layout_constraintTop_toTopOf="@+id/send_img">

                        </EditText>

                        <ImageView
                            android:id="@+id/ans_custome_txt_send"
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_marginEnd="@dimen/_12sdp"
                            android:src="@drawable/baseline_send_24"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="@+id/ans_three_edit"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/ans_three_edit"
                            app:tint="@color/appcolor">

                        </ImageView>


                    </androidx.constraintlayout.widget.ConstraintLayout>


                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>



    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>