<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/itemclick"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_280sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/main_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/_22sdp"
                app:cardElevation="@dimen/_2sdp"
                app:cardUseCompatPadding="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:id="@+id/access_now_btn"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:layout_height="@dimen/_37sdp"
                        android:scaleType="fitXY"
                        android:src="@drawable/sub_dialog_button"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                    </ImageView>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/btn_new_arrow"
                        android:layout_marginEnd="@dimen/_20sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/access_now_btn"
                        app:layout_constraintEnd_toEndOf="@+id/access_now_btn"
                        app:layout_constraintTop_toTopOf="@+id/access_now_btn">

                    </ImageView>


                     <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/access_now"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_15sdp"
                        android:includeFontPadding="false"
                        android:fontFamily="@font/rubikmedium"
                        app:layout_constraintBottom_toBottomOf="@+id/access_now_btn"
                        app:layout_constraintEnd_toEndOf="@+id/access_now_btn"
                        app:layout_constraintStart_toStartOf="@+id/access_now_btn"
                        app:layout_constraintTop_toTopOf="@+id/access_now_btn">.
                     </com.google.android.material.textview.MaterialTextView>

                     <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:id="@+id/txt1"
                        android:layout_height="wrap_content"
                        android:textColor="#C0C0C0"
                        android:gravity="center"
                        android:fontFamily="@font/lato_regular"
                        android:textSize="@dimen/_11sdp"
                        android:singleLine="true"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:text="@string/upgrade_to_enjoy_unlimited_messaging_features"
                        app:layout_constraintBottom_toTopOf="@+id/access_now_btn"
                        app:layout_constraintEnd_toEndOf="@+id/access_now_btn"
                        app:layout_constraintStart_toStartOf="@+id/access_now_btn">

                     </com.google.android.material.textview.MaterialTextView>


                     <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:id="@+id/txt2"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black2"
                        android:gravity="center"
                        android:fontFamily="@font/lato_regular"
                        android:textSize="@dimen/_14sdp"
                        android:singleLine="true"
                        android:layout_marginBottom="@dimen/_5sdp"
                        android:text="@string/messages_sms_amp_private_chat"
                        app:layout_constraintBottom_toTopOf="@+id/txt1"
                        app:layout_constraintEnd_toEndOf="@+id/access_now_btn"
                        app:layout_constraintStart_toStartOf="@+id/access_now_btn">

                     </com.google.android.material.textview.MaterialTextView>

                     <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:id="@+id/txt3"
                        android:layout_height="wrap_content"
                        android:textColor="@color/appcolor"
                        android:gravity="center"
                        android:fontFamily="@font/lato_bold"
                        android:textSize="@dimen/_20sdp"
                        android:singleLine="true"
                        android:layout_marginBottom="@dimen/_1sdp"
                        android:text="@string/unlock_unlimited"
                        app:layout_constraintBottom_toTopOf="@+id/txt2"
                        app:layout_constraintEnd_toEndOf="@+id/access_now_btn"
                        app:layout_constraintStart_toStartOf="@+id/access_now_btn">

                     </com.google.android.material.textview.MaterialTextView>

                    <ImageView
                        android:id="@+id/imageView50"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_margin="@dimen/_10sdp"
                        android:scaleType="fitXY"
                        android:src="@drawable/sub_dialog_bg"
                        app:layout_constraintBottom_toTopOf="@+id/txt3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                    </ImageView>

                    <ImageView
                        android:id="@+id/imageView51"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/sub_star"
                        app:layout_constraintBottom_toBottomOf="@+id/imageView50"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="@+id/imageView50"
                        app:layout_constraintHeight_percent="0.42"
                        app:layout_constraintStart_toStartOf="@+id/imageView50"
                        app:layout_constraintTop_toTopOf="@+id/imageView50">

                    </ImageView>



                    <ImageView
                        android:id="@+id/imageView52"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintHeight_percent="0.23"
                        android:src="@drawable/star_up_to_per"
                        android:layout_marginStart="@dimen/_125sdp"
                        android:layout_marginTop="@dimen/_50sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/imageView51"
                        app:layout_constraintEnd_toEndOf="@+id/imageView50"
                        app:layout_constraintStart_toStartOf="@+id/imageView50"
                        app:layout_constraintTop_toTopOf="@+id/imageView51">

                    </ImageView>

                    <ImageView
                        android:id="@+id/imageView53"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="@dimen/_75sdp"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:src="@drawable/star_up_to"
                        app:layout_constraintBottom_toBottomOf="@+id/imageView52"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="@+id/imageView50"
                        app:layout_constraintHeight_percent="0.12"
                        app:layout_constraintStart_toStartOf="@+id/imageView50"
                        app:layout_constraintTop_toTopOf="@+id/imageView52">

                    </ImageView>

                     <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:text="@string/upto"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:fontFamily="@font/oswaldmedium"
                        android:textSize="@dimen/_10sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/imageView53"
                        app:layout_constraintTop_toTopOf="@+id/imageView53"
                        app:layout_constraintStart_toStartOf="@+id/imageView53"
                        app:layout_constraintEnd_toEndOf="@+id/imageView53"
                        android:layout_height="wrap_content">

                     </com.google.android.material.textview.MaterialTextView>

                     <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:id="@+id/persentage_txt"
                        android:text="@string/off"
                        android:gravity="center"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:lineSpacingExtra="-10dp"
                        android:includeFontPadding="false"
                        android:fontFamily="@font/oswaldmedium"
                        android:textSize="@dimen/_14sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/imageView52"
                        app:layout_constraintTop_toTopOf="@+id/imageView52"
                        app:layout_constraintStart_toStartOf="@+id/imageView52"
                        app:layout_constraintEnd_toEndOf="@+id/imageView52"
                        android:layout_height="wrap_content">

                     </com.google.android.material.textview.MaterialTextView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/dialog_close"
                        style="@style/Widget.App.IconCloseButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        app:icon="@drawable/close_icon"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@null"
                        app:layout_constraintEnd_toEndOf="@+id/imageView50"
                        app:layout_constraintTop_toTopOf="@+id/imageView50" />


                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
