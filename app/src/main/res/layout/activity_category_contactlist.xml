<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="adapter"
            type="com.messenger.phone.number.text.sms.service.apps.adapter.MainMassageAdapter" />

        <variable
            name="isselection"
            type="Boolean" />

        <variable
            name="nomessagefoundchack"
            type="Boolean" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        setchatthemecolorBg="@{0}"


        tools:context=".CategoryContactlistActivity">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/main_menu_ar"
            android:layout_width="match_parent"

            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tool_bar_main"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                setchatthemecolor="@{0}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/defaulttoolshow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="@{isselection ? View.GONE : View.VISIBLE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:visibility="visible"
        android:paddingStart="@dimen/_5sdp"
            android:paddingEnd="@dimen/_5sdp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/back_btn"
                        style="@style/Widget.Material3.Button.IconButton"
                        app:iconSize="@dimen/mf_appbar_back_icon"      android:layout_width="@dimen/mf_appbar_action_size1"
                        android:layout_height="@dimen/mf_appbar_action_size1"
                        android:layout_marginStart="0dp"
                        app:icon="@drawable/recycle_bin_material_ic_arrow_back_rounded"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="?attr/colorOnSurface"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        />

                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textView3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/mf_appbar_title_spacing"
                        android:ellipsize="end"
                        android:maxLines="1"
                   fullappfontstylesemibold="@{0}"
                        android:text="@string/Add_Contact"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_18sdp"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="@+id/back_btn"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/back_btn"
                        app:layout_constraintTop_toTopOf="@+id/back_btn"
                        tools:visibility="visible">

                     </com.google.android.material.textview.MaterialTextView>


                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/selectioncontenar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="@dimen/_5sdp"
                    android:paddingEnd="@dimen/_5sdp"
                    android:visibility="@{isselection ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:visibility="gone">



                    <ImageView
                        android:id="@+id/message_selection_close"
                        android:layout_width="@dimen/mf_appbar_action_size"
                        android:layout_height="@dimen/mf_appbar_action_size"
                        android:layout_marginStart="0dp"
                        android:padding="@dimen/mf_appbar_action_padding"
                        android:src="@drawable/close_icon"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white">

                    </ImageView>


                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/selectioncount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/mf_appbar_title_spacing"
                        android:layout_marginEnd="@dimen/mf_appbar_title_spacing"
                        android:ellipsize="end"
                        android:maxLines="1"
                       fullappfontstyleregular="@{0}"
                        android:text="1 selected"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_18sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/message_selection_close"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/message_selection_close"
                        app:layout_constraintTop_toTopOf="@+id/message_selection_close">

                     </com.google.android.material.textview.MaterialTextView>


                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.appbar.AppBarLayout>


        <ImageView
            android:id="@+id/txt_img"
            android:layout_width="@dimen/_15sdp"
            android:layout_height="@dimen/_15sdp"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:src="@drawable/advertising_txt"
            app:layout_constraintBottom_toTopOf="@+id/search_bar_con"
            app:layout_constraintEnd_toStartOf="@+id/txt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/main_menu_ar">

        </ImageView>

         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
           fullappfontstyleregular="@{0}"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="@string/Select_the_conversations_you_want"
            setchatthemecolorTintTxtFullappForLocksetup="@{0}"
            android:textSize="@dimen/_10sdp"
            app:layout_constraintBottom_toBottomOf="@+id/txt_img"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/txt_img"
            app:layout_constraintTop_toTopOf="@+id/txt_img">

         </com.google.android.material.textview.MaterialTextView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/search_bar_con"
            android:layout_width="0dp"
            android:layout_height="45dp"
            app:layout_constraintTop_toBottomOf="@+id/txt_img"
            android:background="@drawable/serch_bg"
            android:layout_marginTop="@dimen/_6sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.93"
            tools:layout_editor_absoluteY="19dp">


            <EditText
                android:id="@+id/SearchContact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_10sdp"
                android:background="@null"
                android:hint="@string/Searchconversationnew"
                android:layout_marginStart="@dimen/_15sdp"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:singleLine="true"
                android:textColorHint="#87A0B7"
                android:textSize="@dimen/_15sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/serch_cleasr"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </EditText>

            <ImageView
                android:id="@+id/serch_cleasr"
                android:layout_width="@dimen/mf_appbar_action_size"
                android:layout_height="@dimen/mf_appbar_action_size"
                android:src="@drawable/ic_serch_close_new"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="@dimen/mf_appbar_action_edge_margin"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible">

            </ImageView>



        </androidx.constraintlayout.widget.ConstraintLayout>



        <com.qtalk.recyclerviewfastscroller.RecyclerViewFastScroller
            android:id="@+id/conversations_fastscroller"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/search_bar_con">

            <com.simplemobiletools.commons.views.MyRecyclerView
                android:id="@+id/allmassagerecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adapter="@{adapter}"
                android:clipToPadding="false"
                android:layoutAnimation="@anim/layout_animation"
                android:orientation="vertical"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="none"
                app:layoutManager="com.simplemobiletools.commons.views.MyLinearLayoutManager">

            </com.simplemobiletools.commons.views.MyRecyclerView>

        </com.qtalk.recyclerviewfastscroller.RecyclerViewFastScroller>


        <ImageView
            android:id="@+id/imageView15"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/archivedmessage_bg"
            android:visibility="@{nomessagefoundchack ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.4">

        </ImageView>

         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/nomessagefound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/No_archive_found"
            android:textColor="#A8AEB4"
            android:textSize="@dimen/_15sdp"
            android:visibility="@{nomessagefoundchack ? View.VISIBLE : View.GONE}"
            app:layout_constraintEnd_toEndOf="@+id/imageView15"
            app:layout_constraintStart_toStartOf="@+id/imageView15"
            app:layout_constraintTop_toBottomOf="@+id/imageView15"
            tools:visibility="visible">

         </com.google.android.material.textview.MaterialTextView>

        <Button
            android:layout_width="@dimen/_150sdp"
            android:layout_height="@dimen/_40sdp"
            android:text="@string/Done"
            android:id="@+id/message_add"
            android:textSize="@dimen/_13sdp"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            android:padding="@dimen/_5sdp"
            android:visibility="gone"
            tools:visibility="visible"
            android:backgroundTint="#388DDC"
            android:layout_marginBottom="@dimen/_20sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

        </Button>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
