<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@drawable/bottom_dialog_bg"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:id="@+id/mCLYearLayout"
        android:layout_width="0dp"
        android:layout_height="@dimen/_107sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_20sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.15"
        app:layout_constraintStart_toEndOf="@+id/mCLMonthLayout"
        app:layout_constraintTop_toBottomOf="@+id/mCLLIFELayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/yearconstraintid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:background="@drawable/bgyear"
            android:gravity="start"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/mIVYearSelection"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_15sdp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/mycheckiconsvg"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.45"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txt_auto_renew_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:maxLength="12"
                android:paddingEnd="@dimen/_5sdp"
                android:singleLine="true"
                android:text="@string/Yearly_new_plan"
                android:textColor="#838383"
                android:textSize="@dimen/_13ssp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.13" />


            <View
                android:id="@+id/view3"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="@dimen/_1sdp"
                android:background="#4A4A4A"
                app:layout_constraintEnd_toEndOf="@+id/txt_auto_renew_year"
                app:layout_constraintStart_toStartOf="@+id/txt_auto_renew_year"
                app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_year" />


             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textView10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:text="₹4800"
                android:textColor="#838383"
                android:textSize="@dimen/_8sdp"
                app:layout_constraintBottom_toTopOf="@+id/txtYearlyPrice"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_year">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtYearlyPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lines="1"
                android:maxLength="27"
                android:text="₹4,100.00"
                android:textColor="#838383"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view3"
                app:layout_constraintVertical_bias="0.36" />


             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/yearstaticprice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:text="@string/per_week"
                android:textColor="#838383"
                android:textSize="@dimen/_7sdp"
                android:visibility="visible"
                app:layout_constraintEnd_toStartOf="@+id/yesrstatic"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtYearlyPrice">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/yesrstatic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:text="@string/per_week_new"
                android:textColor="#838383"
                android:textSize="@dimen/_7sdp"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@+id/yearstaticprice"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/yearstaticprice"
                app:layout_constraintTop_toTopOf="@+id/yearstaticprice">

             </com.google.android.material.textview.MaterialTextView>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </RelativeLayout>


    <androidx.cardview.widget.CardView
        android:id="@+id/year_discount_show"
        android:layout_width="@dimen/_65sdp"
        android:layout_height="@dimen/_18sdp"
        app:cardBackgroundColor="#2F91EB"
        app:cardCornerRadius="@dimen/_10sdp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/mCLYearLayout"
        app:layout_constraintEnd_toEndOf="@+id/mCLYearLayout"
        app:layout_constraintStart_toStartOf="@+id/mCLYearLayout"
        app:layout_constraintTop_toTopOf="@+id/mCLYearLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                 <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="62%OFF"
                    android:id="@+id/txt_year_discount"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:textSize="@dimen/_8sdp"
                    android:fontFamily="@font/poppins_regular"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                 </com.google.android.material.textview.MaterialTextView>


            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>


    <RelativeLayout
        android:id="@+id/mCLMonthLayout"
        android:layout_width="0dp"
        android:layout_height="@dimen/_107sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_20sdp"
        app:layout_constraintEnd_toStartOf="@+id/mCLYearLayout"
        app:layout_constraintHeight_percent="0.15"
