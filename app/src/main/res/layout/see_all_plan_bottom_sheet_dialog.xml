                app:layout_constraintBottom_toTopOf="@+id/txtlifediscountid"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/lifestatic"
                app:layout_constraintTop_toBottomOf="@+id/lifestatic" />

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtlifediscountid"
