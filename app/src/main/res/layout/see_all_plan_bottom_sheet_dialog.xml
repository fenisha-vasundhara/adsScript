             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="₹4800"
                android:textColor="#838383"
                android:textSize="@dimen/_8sdp"
                app:layout_constraintBottom_toTopOf="@+id/txtMonthlyPrice"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_month">

             </com.google.android.material.textview.MaterialTextView>


            <View
                android:id="@+id/view2"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="@dimen/_1sdp"
                android:background="#4A4A4A"
                app:layout_constraintEnd_toEndOf="@+id/txt_auto_renew_month"
                app:layout_constraintStart_toStartOf="@+id/txt_auto_renew_month"
                app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_month" />

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtMonthlyPrice"
                android:layout_width="65dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lines="1"
                android:maxLength="26"
                android:text="₹820.00"
                android:textColor="#838383"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view2"
                app:layout_constraintVertical_bias="0.36" />

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/monthstaticprice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:text="@string/per_week"
                android:textColor="#838383"
                android:textSize="@dimen/_7sdp"
                android:visibility="visible"
                app:layout_constraintEnd_toStartOf="@+id/monthstatic"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtMonthlyPrice">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/monthstatic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:text="@string/per_week_new"
                android:textColor="#838383"
                android:textSize="@dimen/_7sdp"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@+id/monthstaticprice"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/monthstaticprice"
                app:layout_constraintTop_toTopOf="@+id/monthstaticprice">

             </com.google.android.material.textview.MaterialTextView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/month_discount_show"
        android:layout_width="@dimen/_65sdp"
        android:layout_height="@dimen/_18sdp"
        app:cardBackgroundColor="#D3E3F8"
        app:cardCornerRadius="@dimen/_10sdp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/mCLMonthLayout"
        app:layout_constraintEnd_toEndOf="@+id/mCLMonthLayout"
        app:layout_constraintStart_toStartOf="@+id/mCLMonthLayout"
        app:layout_constraintTop_toTopOf="@+id/mCLMonthLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

             <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="62%OFF"
                android:id="@+id/txt_month_discount"
                android:textColor="@color/black2"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:textSize="@dimen/_8sdp"
                android:fontFamily="@font/poppins_regular"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

             </com.google.android.material.textview.MaterialTextView>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.cardview.widget.CardView>


    <RelativeLayout
        android:id="@+id/mCLWeekLayout"
        android:layout_width="0dp"
        android:layout_height="@dimen/_107sdp"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_marginStart="@dimen/_10sdp"
        app:layout_constraintEnd_toStartOf="@+id/mCLMonthLayout"
        app:layout_constraintHeight_percent="0.15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mCLLIFELayout">

        <androidx.constraintlayout.widget.ConstraintLayout
