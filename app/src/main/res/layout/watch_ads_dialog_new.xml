<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="isdarktheme"
            type="Boolean" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:background="@android:color/transparent"
        android:layout_height="wrap_content">



        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            tools:background="@drawable/pro_dialog_bg"
            android:background="@{isdarktheme ? @drawable/pro_dialog_bg_new : @drawable/pro_dialog_bg}"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imageView48"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:src="@{isdarktheme ? @drawable/pro_dialog_top_new_png :@drawable/pro_dialog_top}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </ImageView>


             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/imageView14"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:gravity="center"
                android:textColor="@{isdarktheme ? @color/white : @color/black2}"
                android:lineSpacingExtra="@dimen/_2sdp"
                android:text="@string/pre_dialog_new"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintBottom_toTopOf="@+id/watchvideo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imageView49">

             </com.google.android.material.textview.MaterialTextView>

            <ImageView
                android:id="@+id/imageView49"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/prodialog_line"
                app:layout_constraintBottom_toTopOf="@+id/imageView14"
                app:layout_constraintEnd_toEndOf="@+id/textView11"
                app:layout_constraintStart_toStartOf="@+id/textView11"
                app:layout_constraintTop_toBottomOf="@+id/textView11">

            </ImageView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textView11"
                fullappfontstylebold="@{0}"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_5sdp"
                android:fontFamily="@font/lato_bold"
                android:text="@string/get_on_with_your_chat"
                android:textColor="@{isdarktheme ? @color/white : @color/black2}"
                android:textSize="@dimen/_18sdp"
                app:layout_constraintBottom_toTopOf="@+id/imageView49"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imageView48"
                app:layout_constraintVertical_chainStyle="packed">

             </com.google.android.material.textview.MaterialTextView>

             <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textView10"
                fullappfontstylemediam="@{0}"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_15sdp"
                android:text="@string/Features"
                android:textColor="#F37321"
                android:textSize="@dimen/_16sdp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/textView11">

             </com.google.android.material.textview.MaterialTextView>


            <ImageView
                android:id="@+id/imageView15"
                android:layout_width="@dimen/_100sdp"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:src="@drawable/line_premiam_dialog">

            </ImageView>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/getpremium"
                android:layout_width="0dp"
                app:layout_constraintTop_toBottomOf="@+id/watchvideo"
                android:layout_height="@dimen/_50sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:background="@drawable/watch_ads_dialog_btn_bg_new"
                android:layout_marginBottom="@dimen/_15sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_weight="1"
                android:elevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0">

                    <ImageView
                        android:id="@+id/imageView12"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginEnd="@dimen/_6sdp"
                        android:src="@drawable/prodialog_button_ic"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHeight_percent="0.6"
                        app:layout_constraintTop_toTopOf="parent">

                    </ImageView>

                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/Premiumtxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/rubikmedium"
                        android:includeFontPadding="false"
                        android:text="@string/skip_ads"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_13sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                     </com.google.android.material.textview.MaterialTextView>


                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/newtxt"
                        fullappfontstyleregular="@{0}"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:includeFontPadding="false"
                        android:text="@string/Without_ads_and_limitations"
                        android:textColor="#3F4347"
                        android:textSize="@dimen/_7sdp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/Premiumtxt"
                        app:layout_constraintTop_toBottomOf="@+id/Premiumtxt">

                     </com.google.android.material.textview.MaterialTextView>


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/watchvideo"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                app:layout_constraintBottom_toTopOf="@+id/getpremium"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:background="@{isdarktheme ? @drawable/watch_ads_dialog_btn_bg_dark:@drawable/watch_ads_dialog_btn_bg}"
                android:elevation="0dp"
                app:layout_constraintTop_toBottomOf="@+id/imageView14"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/imageView11"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:alpha="0.7"
                        android:src="@drawable/ad_wach_dialog"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintWidth_percent="0.10">

                    </ImageView>


                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/Watchtxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/rubikmedium"
                        android:includeFontPadding="false"
                        android:text="@string/watch_ad"
                        android:textColor="@{isdarktheme ? @color/white : @color/black2}"
                        android:textSize="@dimen/_13sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                     </com.google.android.material.textview.MaterialTextView>


                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/featurestxt"
                        fullappfontstyleregular="@{0}"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:includeFontPadding="false"
                        android:text="@string/Watch_the_video_and_schedule_the_message"
                        android:textColor="#3F4347"
                        android:visibility="gone"
                        android:textSize="@dimen/_7sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/Watchtxt"
                        app:layout_constraintTop_toBottomOf="@+id/Watchtxt">

                     </com.google.android.material.textview.MaterialTextView>

                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>



            <ImageView
                android:id="@+id/dialogclose"
                android:layout_width="@dimen/_60sdp"
                android:layout_height="@dimen/_60sdp"
                android:padding="@dimen/_18sdp"
                android:src="@{isdarktheme ? @drawable/wach_ad_dialog :@drawable/wachdialog_close_btn_new}"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_percent="0.08"
                app:layout_constraintTop_toTopOf="parent">

            </ImageView>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>