<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/tutorial_bg">


        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/messageloadinglottie"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_280sdp"
            android:layout_gravity="top"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_autoPlay="true"
            app:lottie_loop="true">

        </com.airbnb.lottie.LottieAnimationView>


         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/body_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_7sdp"
           fullappfontstyleregular="@{0}"
            android:gravity="center"
            android:text="Swipe from the side to check if your\n message has been sent"
            android:textSize="@dimen/_12sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/messageloadinglottie">

         </com.google.android.material.textview.MaterialTextView>

        <Button
            android:id="@+id/idBtnnext"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginEnd="@dimen/_20sdp"
            android:layout_weight="2"
            android:backgroundTint="#85C4FF"
            android:gravity="center"
            android:text="Next"
            android:textColor="#053272"
            android:textSize="@dimen/_10sdp"
            app:layout_constraintBottom_toBottomOf="@+id/idBtnSkip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/idBtnSkip" />


         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/idBtnSkip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_20sdp"
            android:layout_marginBottom="@dimen/_15sdp"
            android:backgroundTint="@color/appcolor"
            android:text="Skip"
            android:textAllCaps="true"
            android:textColor="#99A2AA"
            android:textSize="@dimen/_13sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/body_txt" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>