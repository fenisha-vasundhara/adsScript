<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="textsizechagefor10"
            type="Float" />

        <variable
            name="textsizechagefor13"
            type="Float" />

        <variable
            name="textsizechagefor18"
            type="Float" />

        <variable
            name="textsizechagefor8"
            type="Float" />

        <variable
            name="textsizechagefor15"
            type="Float" />

        <variable
            name="adapter"
            type="com.messenger.phone.number.text.sms.service.apps.adapter.CustomNotificationAdapter" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        setchatthemecolorforHomeScreenBg="@{0}"
        android:layout_width="match_parent"
        android:layout_height="match_parent"


        tools:context=".Custom_Notification_Activity">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/main_menu_ar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tool_bar_main"
                setchatthemecolor="@{0}"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/defaulttoolshow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:background="@color/appcolor"
                    tools:visibility="visible"
        android:paddingStart="@dimen/_5sdp"
            android:paddingEnd="@dimen/_5sdp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/back_btn"
                        style="@style/Widget.Material3.Button.IconButton"
                        app:iconSize="@dimen/mf_appbar_back_icon"       android:layout_width="@dimen/mf_appbar_action_size1"
                        android:layout_height="@dimen/mf_appbar_action_size1"
                        android:layout_marginStart="0dp"
                        app:icon="@drawable/recycle_bin_material_ic_arrow_back_rounded"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="?attr/colorOnSurface"

                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        />

                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textView3"
                        fullappfontstylesemibold="@{0}"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_3sdp"
                        android:text="@string/custom_Notication"
                        setchatthemecolorTintTxt="@{0}"
                        setTextSizeFullApp="@{textsizechagefor18}"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="@+id/back_btn"
                        app:layout_constraintStart_toEndOf="@+id/back_btn"
                        app:layout_constraintTop_toTopOf="@+id/back_btn"
                        tools:visibility="visible">

                     </com.google.android.material.textview.MaterialTextView>

                    <ImageView
                        android:id="@+id/lang_change"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:layout_marginEnd="@dimen/_13sdp"
                        android:src="@drawable/language_arror"
                        setchatthemecolorTintImfullapp="@{0}"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="@+id/textView3"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHeight_percent="0.4"
                        app:layout_constraintTop_toTopOf="@+id/textView3"
                        tools:src="@drawable/language_arror"
                        tools:visibility="visible">

                    </ImageView>


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.appbar.AppBarLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lanbtn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_50sdp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            app:layout_constraintBottom_toTopOf="@+id/nextscroll"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/main_menu_ar"
            android:paddingStart="@dimen/_10sdp"
            android:paddingEnd="@dimen/_10sdp">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                 <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/customnotification"
                    setchatthemecolorTintTxtFullapp="@{0}"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_10sdp"
                    fullappfontstyleregular="@{0}"
                    android:singleLine="true"
                    android:gravity="center"
                    android:text="@string/add_custom_notification"
                    setTextSizeFullApp="@{textsizechagefor13}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed">

                 </com.google.android.material.textview.MaterialTextView>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.core.widget.NestedScrollView
            android:id="@+id/nextscroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/_10sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lanbtn">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ringtonrecyclerview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adapter="@{adapter}"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="20"
                tools:listitem="@layout/custom_notification_item">

            </androidx.recyclerview.widget.RecyclerView>

        </androidx.core.widget.NestedScrollView>

        <ProgressBar
            android:id="@+id/progressbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/appcolor"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        </ProgressBar>

         <com.google.android.material.textview.MaterialTextView
            setchatthemecolorTintTxtFullapp="@{0}"
            android:id="@+id/notfound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default Notification Audio\nNot Found"
            setTextSizeFullApp="@{textsizechagefor15}"
            android:gravity="center"
            android:visibility="gone"
            android:fontFamily="@font/poppins_regular"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/nextscroll">

         </com.google.android.material.textview.MaterialTextView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>