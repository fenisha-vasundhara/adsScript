<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"


        setchatthemecolorforHomeScreenBg="@{0}"
        tools:context=".AfterCallScreen.fragment.AfterCallMoreNewFragment">


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:id="@+id/card"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_15sdp"
                    android:layout_marginBottom="@dimen/_10sdp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardCornerRadius="@dimen/_15sdp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">


                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/Edit_contact"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/imageView55"
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_marginStart="@dimen/_20sdp"
                                android:src="@drawable/baseline_edit_24"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                             <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textView51"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_15sdp"
                                android:text="@string/edit_contact"
                                setchatthemecolorTintTxt="@{0}"
                                android:textSize="@dimen/_14sdp"
                                app:layout_constraintBottom_toBottomOf="@+id/imageView55"
                                app:layout_constraintStart_toEndOf="@+id/imageView55"
                                app:layout_constraintTop_toTopOf="@+id/imageView55">

                             </com.google.android.material.textview.MaterialTextView>

                            <ImageView
                                android:id="@+id/imageView66"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_marginEnd="@dimen/_12sdp"
                                android:src="@drawable/baseline_keyboard_arrow_right_24"
                                app:layout_constraintBottom_toBottomOf="@+id/textView51"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@+id/textView51"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                            <View
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_1sdp"
                                android:layout_marginEnd="@dimen/_10sdp"
                                android:background="#A4A4A4"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="@+id/textView51">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/Messages"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/Edit_contact">

                            <ImageView
                                android:id="@+id/imageView56"
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_marginStart="@dimen/_20sdp"
                                android:src="@drawable/baseline_message_24"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                             <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textView52"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_15sdp"
                                android:text="@string/messages_new"
                                setchatthemecolorTintTxt="@{0}"
                                android:textSize="@dimen/_14sdp"
                                app:layout_constraintBottom_toBottomOf="@+id/imageView56"
                                app:layout_constraintStart_toEndOf="@+id/imageView56"
                                app:layout_constraintTop_toTopOf="@+id/imageView56">

                             </com.google.android.material.textview.MaterialTextView>

                            <ImageView
                                android:id="@+id/imageView67"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_marginEnd="@dimen/_12sdp"
                                android:src="@drawable/baseline_keyboard_arrow_right_24"
                                app:layout_constraintBottom_toBottomOf="@+id/textView52"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@+id/textView52"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                            <View
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_1sdp"
                                android:layout_marginEnd="@dimen/_10sdp"
                                android:background="#A4A4A4"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="@+id/textView52">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/Send_Mail"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/Messages">

                            <ImageView
                                android:id="@+id/imageView57"
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_marginStart="@dimen/_20sdp"
                                android:src="@drawable/baseline_alternate_email_24"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                             <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textView511"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_15sdp"
                                android:text="@string/send_mail"
                                setchatthemecolorTintTxt="@{0}"
                                android:textSize="@dimen/_14sdp"
                                app:layout_constraintBottom_toBottomOf="@+id/imageView57"
                                app:layout_constraintStart_toEndOf="@+id/imageView57"
                                app:layout_constraintTop_toTopOf="@+id/imageView57">

                             </com.google.android.material.textview.MaterialTextView>

                            <ImageView
                                android:id="@+id/imageView68"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_marginEnd="@dimen/_12sdp"
                                android:src="@drawable/baseline_keyboard_arrow_right_24"
                                app:layout_constraintBottom_toBottomOf="@+id/textView511"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@+id/textView511"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                            <View
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_1sdp"
                                android:layout_marginEnd="@dimen/_10sdp"
                                android:background="#A4A4A4"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="@+id/textView511">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/Calendar"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/Send_Mail">

                            <ImageView
                                android:id="@+id/imageView58"
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_marginStart="@dimen/_20sdp"
                                android:src="@drawable/baseline_calendar_month_24"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                             <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textView55"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_15sdp"
                                android:text="@string/calendar"
                                setchatthemecolorTintTxt="@{0}"
                                android:textSize="@dimen/_14sdp"
                                app:layout_constraintBottom_toBottomOf="@+id/imageView58"
                                app:layout_constraintStart_toEndOf="@+id/imageView58"
                                app:layout_constraintTop_toTopOf="@+id/imageView58">

                             </com.google.android.material.textview.MaterialTextView>

                            <ImageView
                                android:id="@+id/imageView69"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_marginEnd="@dimen/_12sdp"
                                android:src="@drawable/baseline_keyboard_arrow_right_24"
                                app:layout_constraintBottom_toBottomOf="@+id/textView55"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@+id/textView55"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                            <View
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_1sdp"
                                android:layout_marginEnd="@dimen/_10sdp"
                                android:background="#A4A4A4"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="@+id/textView55">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/Web_aftercall"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/Calendar">

                            <ImageView
                                android:id="@+id/imageView59"
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_marginStart="@dimen/_20sdp"
                                android:src="@drawable/baseline_web_24"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                             <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textView59"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_15sdp"
                                android:text="@string/web"
                                setchatthemecolorTintTxt="@{0}"
                                android:textSize="@dimen/_14sdp"
                                app:layout_constraintBottom_toBottomOf="@+id/imageView59"
                                app:layout_constraintStart_toEndOf="@+id/imageView59"
                                app:layout_constraintTop_toTopOf="@+id/imageView59">

                             </com.google.android.material.textview.MaterialTextView>

                            <ImageView
                                android:id="@+id/imageView60"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_marginEnd="@dimen/_12sdp"
                                android:src="@drawable/baseline_keyboard_arrow_right_24"
                                app:layout_constraintBottom_toBottomOf="@+id/textView59"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@+id/textView59"
                                setchatthemecolorTintImfullapp="@{0}">

                            </ImageView>


                        </androidx.constraintlayout.widget.ConstraintLayout>


                    </androidx.constraintlayout.widget.ConstraintLayout>


                </androidx.cardview.widget.CardView>

            </LinearLayout>


        </ScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>