<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="adapter"
            type="com.messenger.phone.number.text.sms.service.apps.adapter.Schedule_Message_Show_Adapter" />

        <variable
            name="isnotfound"
            type="Boolean" />

        <variable
            name="textsizechagefor10"
            type="Float" />

        <variable
            name="textsizechagefor13"
            type="Float" />

        <variable
            name="textsizechagefor18"
            type="Float" />

        <variable
            name="textsizechagefor8"
            type="Float" />

        <variable
            name="textsizechagefor15"
            type="Float" />


    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        tools:context=".Schedule_Message_Show_Activity">

        <LinearLayout
            android:id="@+id/vAnd15StatusBar"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/tool_bar_main"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="?attr/colorSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/vAnd15StatusBar">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/defaulttoolshow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible"
                android:paddingStart="@dimen/_5sdp"
                android:paddingEnd="@dimen/_5sdp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/back_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="@dimen/mf_appbar_action_size1"
                    android:layout_height="@dimen/mf_appbar_action_size1"
                    android:layout_marginStart="0dp"
                    app:icon="@drawable/recycle_bin_material_ic_arrow_back_rounded"
                    app:iconGravity="textStart"
                    app:iconSize="@dimen/mf_appbar_back_icon"        app:iconPadding="0dp"
                    app:iconTint="?attr/colorOnSurface"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/textView3"
                    fullappfontstylesemibold="@{0}"
                    setTextSizeFullApp="@{textsizechagefor18}"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/mf_appbar_title_spacing"
                    android:text="@string/schedule_message"
                    android:textColor="?attr/colorOnSurface"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="@+id/back_btn"
                    app:layout_constraintStart_toEndOf="@+id/back_btn"
                    app:layout_constraintTop_toTopOf="@+id/back_btn"
                    tools:visibility="visible">

                </com.google.android.material.textview.MaterialTextView>


            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.qtalk.recyclerviewfastscroller.RecyclerViewFastScroller
            android:id="@+id/conversations_fastscroller"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="@{isnotfound ? View.GONE : View.VISIBLE}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tool_bar_main"
            android:paddingStart="@dimen/_10sdp"
            android:paddingEnd="@dimen/_10sdp">

            <com.messenger.phone.number.text.sms.service.apps.recyclerviewCustom.MyRecyclerView
                android:id="@+id/allmassagerecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentTop="true"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="@dimen/_5sdp"
                android:adapter="@{adapter}"
                android:clipToPadding="false"
                android:layoutAnimation="@anim/layout_animation"
                android:orientation="vertical"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="none"
                app:layoutManager=".recyclerviewCustom.MyLinearLayoutManager">

            </com.messenger.phone.number.text.sms.service.apps.recyclerviewCustom.MyRecyclerView>

        </com.qtalk.recyclerviewfastscroller.RecyclerViewFastScroller>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/comman_txt"
            setTextSizeFullApp="@{textsizechagefor13}"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="italic"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/Send_a_message_automatically"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="@{isnotfound ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toTopOf="@+id/schedule_message_placeholder_action"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tool_bar_main"
            app:layout_constraintVertical_chainStyle="packed">

        </com.google.android.material.textview.MaterialTextView>

        <com.simplemobiletools.commons.views.MyTextView
            android:id="@+id/schedule_message_placeholder_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ripple_all_corners"
            android:gravity="center"
            android:text="@string/new_message"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="@dimen/activity_margin"
            setTextSizeFullApp="@{textsizechagefor13}"
            android:visibility="@{isnotfound ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/comman_txt" />


        <ImageView
            android:id="@+id/schedule_message_send_btn"
            android:layout_width="@dimen/_45sdp"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginEnd="@dimen/_20sdp"
            android:layout_marginBottom="@dimen/_20sdp"
            android:src="@drawable/baseline_send_24"
            app:layout_constraintBottom_toBottomOf="parent"
            android:elevation="@dimen/_3sdp"
            android:padding="@dimen/_10sdp"
            tools:background="@drawable/circle_background"
            tools:backgroundTint="?attr/colorPrimary"
            app:layout_constraintEnd_toEndOf="parent">

        </ImageView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
