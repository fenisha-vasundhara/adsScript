<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="textsizechagefor10"
            type="Float" />

        <variable
            name="textsizechagefor13"
            type="Float" />

        <variable
            name="textsizechagefor18"
            type="Float" />

        <variable
            name="textsizechagefor8"
            type="Float" />

        <variable
            name="textsizechagefor15"
            type="Float" />

        <variable
            name="adapterdata"
            type="com.messenger.phone.number.text.sms.service.apps.modelClass.Customwallpaperadaptermodel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/Dark"
            android:layout_width="@dimen/_75ssp"
            android:layout_height="@dimen/_90sdp"
            android:layout_marginTop="@dimen/_10ssp"
            android:layout_marginEnd="@dimen/_10ssp"
            android:layout_weight="1"
            app:cardCornerRadius="@dimen/_6sdp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/theme_selected_font_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@{adapterdata.img}"
                tools:background="@drawable/customwallpaper1">

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.cardview.widget.CardView>

         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textView23"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
           fullappfontstyleregular="@{0}"
            android:includeFontPadding="false"
            android:text="@{adapterdata.name}"
            android:gravity="center"
            android:maxLines="2"
            android:padding="@dimen/_5sdp"
            tools:text="Select From 234234234343243243243424343 234234324"
            android:textColor="?attr/colorOnSurface"
            setTextSizeFullApp="@{textsizechagefor8}"
            app:layout_constraintBottom_toBottomOf="@+id/Dark"
            app:layout_constraintEnd_toEndOf="@+id/Dark"
            app:layout_constraintStart_toStartOf="@+id/Dark"
            app:layout_constraintTop_toTopOf="@+id/Dark"
            app:layout_constraintVertical_bias="0.92">

         </com.google.android.material.textview.MaterialTextView>

        <ImageView
            android:id="@+id/themselected"
            android:layout_width="@dimen/_15sdp"
            android:layout_height="@dimen/_15sdp"
            android:src="@drawable/customwallpaperselectioniconbtn"
            android:visibility="@{adapterdata.isselected ? View.VISIBLE : View.GONE}"
            app:layout_constraintEnd_toEndOf="@+id/Dark"
            app:layout_constraintStart_toStartOf="@+id/guideline"
            app:layout_constraintTop_toTopOf="@+id/guideline2">

        </ImageView>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.8" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.06" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
