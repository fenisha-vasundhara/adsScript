<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <variable
            name="textsizechagefor10"
            type="Float" />

        <variable
            name="textsizechagefor13"
            type="Float" />

        <variable
            name="textsizechagefor18"
            type="Float" />

        <variable
            name="textsizechagefor8"
            type="Float" />

        <variable
            name="textsizechagefor15"
            type="Float" />

    </data>

    <LinearLayout
        android:id="@+id/main_lnr_spr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/bullet_icon"
            android:layout_width="@dimen/_7sdp"
            android:layout_height="@dimen/_7sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/your_bullet_icon" />

         <com.google.android.material.textview.MaterialTextView
            android:id="@+id/spinner_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="10dp"
            android:layout_marginStart="@dimen/_5sdp"
            android:text="@string/Show_character_count"
            setchatthemecolorTintTxtFullapp="@{0}"
            setTextSizeFullApp="@{textsizechagefor13}" />
    </LinearLayout>
</layout>