<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/itemclick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/_15sdp"
                app:cardElevation="@dimen/_2sdp"
                app:cardUseCompatPadding="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    setchatthemecolorBgIntro2="@{0}">


                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_18sdp"
                        android:layout_marginTop="@dimen/_18sdp"
                        android:text="@string/permissions"
                        setchatthemecolorTintTxt="@{0}"
                        android:textSize="@dimen/_15sdp"
                        app:layout_constraintHorizontal_bias="0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                     </com.google.android.material.textview.MaterialTextView>

                    <ImageView
                        android:id="@+id/imageView61"
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:layout_marginTop="@dimen/_13sdp"
                        android:src="@drawable/baseline_call_24"
                        android:tint="@color/appcolor"
                        app:layout_constraintStart_toStartOf="@+id/textView"
                        app:layout_constraintTop_toBottomOf="@+id/textView">

                    </ImageView>

                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/drivingmodetxtnew"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="@dimen/_20sdp"
                        android:gravity="center|start"
                        android:includeFontPadding="false"
                        android:text="Phone status"
                        setchatthemecolorTintTxt="@{0}"
                        android:textSize="@dimen/_13sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/imageView61"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHeight_percent="0.22"
                        app:layout_constraintStart_toEndOf="@+id/imageView61"
                        app:layout_constraintTop_toTopOf="@+id/imageView61"
                        app:layout_constraintWidth_percent="0.88">

                     </com.google.android.material.textview.MaterialTextView>

                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/txt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center|start"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:text="@string/permission_dialog_txt"
                        android:textColor="@color/lightPermissionContent"
                        android:textSize="@dimen/_10sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/drivingmodetxtnew"
                        app:layout_constraintTop_toBottomOf="@+id/drivingmodetxtnew">

                     </com.google.android.material.textview.MaterialTextView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        app:layout_constraintBottom_toTopOf="@+id/con"
                        app:layout_constraintTop_toBottomOf="@+id/txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginStart="@dimen/_18sdp"
                        android:layout_marginEnd="@dimen/_18sdp"
                        app:cardBackgroundColor="#2D4AA6FB"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_marginTop="@dimen/_13sdp"
                        android:id="@+id/tips_layout"
                        android:layout_height="wrap_content">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:padding="@dimen/_10sdp"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/outline_privacy_tip_24"
                                android:layout_width="@dimen/_20sdp"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                android:layout_height="@dimen/_20sdp"
                                android:src="@drawable/outline_privacy_tip_24"
                                app:tint="@color/appcolor">

                            </ImageView>

                             <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/txt2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center|start"
                                android:includeFontPadding="false"
                                android:layout_marginStart="@dimen/_10sdp"
                                android:text="@string/your_contacts_and_messages_are_safe_and_will_not_be_shared_with_anyone"
                                setchatthemecolorTintTxt="@{0}"
                                android:textSize="@dimen/_10sdp"
                                app:layout_constraintBottom_toBottomOf="@+id/outline_privacy_tip_24"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/outline_privacy_tip_24"
                                app:layout_constraintTop_toTopOf="@+id/outline_privacy_tip_24">

                             </com.google.android.material.textview.MaterialTextView>

                        </androidx.constraintlayout.widget.ConstraintLayout>


                    </androidx.cardview.widget.CardView>


                     <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/con"
                        android:layout_width="wrap_content"
                        android:layout_marginBottom="@dimen/_18sdp"
                        android:layout_marginTop="@dimen/_18sdp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="@string/Continue"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:textSize="@dimen/_12sdp"
                        android:textColor="@color/appcolor"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tips_layout">

                     </com.google.android.material.textview.MaterialTextView>


                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>