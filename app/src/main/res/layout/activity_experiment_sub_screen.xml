<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewmodel"
            type="com.demo.adsmanage.viewmodel.SubscriptionExperimentViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".Activity.Experiment_Sub_Screen_Activity">

        <LinearLayout
            android:id="@+id/vAnd15StatusBar"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/white"
            android:orientation="vertical"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/img_close"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="0dp"
            android:layout_marginEnd="@dimen/_5sdp"
            android:adjustViewBounds="true"
            android:padding="@dimen/_2sdp"
            android:scaleType="fitCenter"
            android:src="@drawable/close_icon_test"
            android:tint="#3B000000"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.020"
            app:layout_constraintTop_toBottomOf="@+id/vAnd15StatusBar" />

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/myviewpager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@+id/mCLLIFELayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/img_close" />

        <com.tbuonomo.viewpagerdotsindicator.WormDotsIndicator
            android:id="@+id/worm_dots_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:dotsColor="#4B69FF"
            app:dotsCornerRadius="10dp"
            app:dotsSize="10dp"
            app:dotsSpacing="4dp"
            app:dotsStrokeColor="#D9D9D9"
            app:dotsStrokeWidth="2dp"
            app:layout_constraintBottom_toBottomOf="@+id/myviewpager"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/myviewpager"
            app:layout_constraintVertical_bias="0.95" />


        <RelativeLayout
            android:id="@+id/mCLLIFELayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/_5sdp"
            app:layout_constraintBottom_toTopOf="@+id/month_discount_show"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.090"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/myviewpager">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lifeconstraintid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_marginEnd="@dimen/_10sdp"
                android:background="@drawable/bgyearnewyearexperiment"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/mIVlifeSelection"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uncheckicon"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintHeight_percent="0.45"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txt_auto_renew_life"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_8sdp"
                    android:ellipsize="marquee"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:paddingEnd="@dimen/_5sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:singleLine="true"
                    android:text="@string/lifetime_static"
                    android:textColor="#313E47"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@+id/lifetime"
                    app:layout_constraintStart_toEndOf="@+id/mIVlifeSelection"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed" />

                <TextView
                    android:id="@+id/lifetime"
                    android:layout_width="0dp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_8sdp"
                    android:ellipsize="marquee"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:paddingEnd="@dimen/_5sdp"
                    android:singleLine="true"
                    android:text="@string/Lifetime_new_m"
                    android:textColor="#313E47"
                    android:textSize="@dimen/_8ssp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/view"
                    app:layout_constraintStart_toEndOf="@+id/mIVlifeSelection"
                    app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_life" />

                <View
                    android:id="@+id/view"
                    android:layout_width="@dimen/_1sdp"
                    android:layout_height="0dp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:background="@color/appcolor"
                    app:layout_constraintBottom_toBottomOf="@+id/txtlifediscountid"
                    app:layout_constraintEnd_toStartOf="@+id/lifestatic"
                    app:layout_constraintTop_toTopOf="@+id/lifestatic">

                </View>


                <TextView
                    android:id="@+id/txtlifePrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lines="1"
                    android:maxLength="26"
                    android:text="₹3500.00"
                    android:textColor="#313E47"
                    android:textSize="@dimen/_11ssp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@+id/txtlifediscountid"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/lifestatic"
                    app:layout_constraintTop_toBottomOf="@+id/lifestatic" />

                <TextView
                    android:id="@+id/txtlifediscountid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lines="1"
                    android:maxLength="26"
                    android:text="₹5200"
                    android:textColor="#313E47"
                    android:textSize="@dimen/_8ssp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/txtlifePrice"
                    app:layout_constraintStart_toStartOf="@+id/txtlifePrice"
                    app:layout_constraintTop_toBottomOf="@+id/txtlifePrice" />


                <TextView
                    android:id="@+id/lifestatic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/offer_price"
                    android:textColor="#838383"
                    android:textSize="@dimen/_8ssp"
                    app:layout_constraintBottom_toTopOf="@+id/txtlifePrice"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed">

                </TextView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </RelativeLayout>


        <ImageView
            android:layout_width="@dimen/_100sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_marginStart="@dimen/_23sdp"
            android:src="@drawable/huryupicon"
            android:layout_marginTop="@dimen/_minus4sdp"
            app:layout_constraintStart_toStartOf="@+id/mCLLIFELayout"
            app:layout_constraintTop_toTopOf="@+id/mCLLIFELayout">

        </ImageView>

        <RelativeLayout
            android:id="@+id/mCLYearLayout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            app:layout_constraintBottom_toTopOf="@+id/textsub"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.18"
            app:layout_constraintStart_toEndOf="@+id/mCLMonthLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/yearconstraintid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:background="@drawable/bgyearnewexperiment"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/mIVYearSelection"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mycheckiconsvg"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintHeight_percent="0.45"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txt_auto_renew_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:maxLength="12"
                    android:paddingEnd="@dimen/_5sdp"
                    android:singleLine="true"
                    android:text="@string/Yearly_new_plan"
                    android:textColor="#838383"
                    android:textSize="@dimen/_13ssp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.13" />


                <View
                    android:id="@+id/view3"
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_1sdp"
                    android:background="#4A4A4A"
                    app:layout_constraintEnd_toEndOf="@+id/txt_auto_renew_year"
                    app:layout_constraintStart_toStartOf="@+id/txt_auto_renew_year"
                    app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_year" />


                <TextView
                    android:id="@+id/textView10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:text="₹4420"
                    android:textColor="#838383"
                    android:textSize="@dimen/_8sdp"
                    app:layout_constraintBottom_toTopOf="@+id/txtYearlyPrice"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_year">

                </TextView>

                <TextView
                    android:id="@+id/txtYearlyPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lines="1"
                    android:maxLength="27"
                    android:text="₹1550.00"
                    android:textColor="#838383"
                    android:textSize="@dimen/_13sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/view3"
                    app:layout_constraintVertical_bias="0.36" />


                <TextView
                    android:id="@+id/yearstaticprice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:text="₹30"
                    android:textColor="#838383"
                    android:textSize="@dimen/_7sdp"
                    android:visibility="visible"
                    app:layout_constraintEnd_toStartOf="@+id/yesrstatic"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txtYearlyPrice">

                </TextView>

                <TextView
                    android:id="@+id/yesrstatic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:text="@string/per_week_new"
                    android:textColor="#838383"
                    android:textSize="@dimen/_7sdp"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="@+id/yearstaticprice"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/yearstaticprice"
                    app:layout_constraintTop_toTopOf="@+id/yearstaticprice">

                </TextView>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </RelativeLayout>


        <androidx.cardview.widget.CardView
            android:id="@+id/year_discount_show"
            android:layout_width="@dimen/_65sdp"
            android:layout_height="@dimen/_18sdp"
            app:cardBackgroundColor="#2F91EB"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@+id/mCLYearLayout"
            app:layout_constraintEnd_toEndOf="@+id/mCLYearLayout"
            app:layout_constraintStart_toStartOf="@+id/mCLYearLayout"
            app:layout_constraintTop_toTopOf="@+id/mCLYearLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/txt_year_discount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_regular"
                        android:includeFontPadding="false"
                        android:text="64%OFF"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_8sdp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                    </TextView>


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>


        <TextView
            android:id="@+id/textsub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:lines="1"
            android:paddingBottom="@dimen/_6sdp"
            android:text="@string/Renewal_is_automatic"
            android:textColor="#B5B7B8"
            android:textSize="@dimen/_10sdp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/mCLMonthLayout" />


        <RelativeLayout
            android:id="@+id/mCLMonthLayout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            app:layout_constraintBottom_toTopOf="@+id/textsub"
            app:layout_constraintEnd_toStartOf="@+id/mCLYearLayout"
            app:layout_constraintHeight_percent="0.18"
            app:layout_constraintStart_toEndOf="@+id/mCLWeekLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/monthconstraintid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bgyearopacitynewexperiment"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/mIVMonthSelection"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uncheckicon"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintHeight_percent="0.45"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txt_auto_renew_month"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLength="12"
                    android:singleLine="true"
                    android:text="@string/Monthly_new_plan"
                    android:textColor="#838383"
                    android:textSize="@dimen/_13ssp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.13" />


                <TextView
                    android:id="@+id/textView9"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="₹340"
                    android:textColor="#838383"
                    android:textSize="@dimen/_8sdp"
                    app:layout_constraintBottom_toTopOf="@+id/txtMonthlyPrice"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_month">

                </TextView>


                <View
                    android:id="@+id/view2"
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_1sdp"
                    android:background="#4A4A4A"
                    app:layout_constraintEnd_toEndOf="@+id/txt_auto_renew_month"
                    app:layout_constraintStart_toStartOf="@+id/txt_auto_renew_month"
                    app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_month" />

                <TextView
                    android:id="@+id/txtMonthlyPrice"
                    android:layout_width="65dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lines="1"
                    android:maxLength="26"
                    android:text="₹260.00"
                    android:textColor="#838383"
                    android:textSize="@dimen/_13sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/view2"
                    app:layout_constraintVertical_bias="0.36" />

                <TextView
                    android:id="@+id/monthstaticprice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:text="₹65"
                    android:textColor="#838383"
                    android:textSize="@dimen/_7sdp"
                    android:visibility="visible"
                    app:layout_constraintEnd_toStartOf="@+id/monthstatic"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txtMonthlyPrice">

                </TextView>

                <TextView
                    android:id="@+id/monthstatic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:text="@string/per_week_new"
                    android:textColor="#838383"
                    android:textSize="@dimen/_7sdp"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="@+id/monthstaticprice"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/monthstaticprice"
                    app:layout_constraintTop_toTopOf="@+id/monthstaticprice">

                </TextView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/month_discount_show"
            android:layout_width="@dimen/_65sdp"
            android:layout_height="@dimen/_18sdp"
            app:cardBackgroundColor="#D3E3F8"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@+id/mCLMonthLayout"
            app:layout_constraintEnd_toEndOf="@+id/mCLMonthLayout"
            app:layout_constraintStart_toStartOf="@+id/mCLMonthLayout"
            app:layout_constraintTop_toTopOf="@+id/mCLMonthLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/txt_month_discount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:text="23%OFF"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_8sdp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </TextView>


            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.cardview.widget.CardView>




        <RelativeLayout
            android:id="@+id/mCLWeekLayout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            app:layout_constraintBottom_toTopOf="@+id/textsub"
            app:layout_constraintEnd_toStartOf="@+id/mCLMonthLayout"
            app:layout_constraintHeight_percent="0.18"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/weekconstraintid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:background="@drawable/bgyearopacitynewexperiment"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/mIVweekSelection"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uncheckicon"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintHeight_percent="0.45"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txt_auto_renew_week"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLength="12"
                    android:singleLine="true"
                    android:text="@string/Weekly_new_plan"
                    android:textColor="#838383"
                    android:textSize="@dimen/_13ssp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.13"
                    app:layout_constraintVertical_chainStyle="packed" />

                <View
                    android:id="@+id/weekview2"
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_1sdp"
                    android:background="#838383"
                    android:backgroundTint="#838383"
                    app:layout_constraintEnd_toEndOf="@+id/txt_auto_renew_week"
                    app:layout_constraintStart_toStartOf="@+id/txt_auto_renew_week"
                    app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_week" />


                <TextView
                    android:id="@+id/txtweekPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lines="1"
                    android:maxLength="26"
                    android:text="₹85.00"
                    android:textColor="#838383"
                    android:textSize="@dimen/_13sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txt_auto_renew_week"
                    app:layout_constraintVertical_bias="0.36"
                    app:layout_constraintVertical_chainStyle="packed" />

                <TextView
                    android:id="@+id/weekstatic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:text="@string/per_week"
                    android:textColor="#838383"
                    android:textSize="@dimen/_7sdp"
                    android:visibility="visible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txtweekPrice">

                </TextView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/week_discount_show"
            android:layout_width="@dimen/_65sdp"
            android:layout_height="@dimen/_18sdp"
            app:cardBackgroundColor="#D3E3F8"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@+id/mCLWeekLayout"
            app:layout_constraintEnd_toEndOf="@+id/mCLWeekLayout"
            app:layout_constraintStart_toStartOf="@+id/mCLWeekLayout"
            app:layout_constraintTop_toTopOf="@+id/mCLWeekLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/txt_week_discount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:text="Popular"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_8sdp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                </TextView>


            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/mCLUnlockLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_6sdp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0884F9"
            app:layout_constraintBottom_toTopOf="@+id/txtBottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.08"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textsub">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:shimmer_auto_start="true"
                app:shimmer_duration="2000"
                app:shimmer_fixed_width="@dimen/_160sdp"
                app:shimmer_highlight_color="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/shimmer_layout">

                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <TextView
                android:id="@+id/txt_unlock_kriadl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_6sdp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lines="1"
                android:text="@string/Continue"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="@dimen/_15sdp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/txtBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_6sdp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:lines="1"
            android:maxLength="36"
            android:text="@string/Renewal_is_automatic"
            android:textColor="#C8D0D7"
            android:textSize="@dimen/_10sdp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/mCLUnlockLayout2"
            app:layout_constraintEnd_toEndOf="@+id/mCLUnlockLayout"
            app:layout_constraintStart_toStartOf="@+id/mCLUnlockLayout" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mCLUnlockLayout2"
            android:layout_width="match_parent"
            android:layout_marginBottom="@dimen/_5sdp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/txtTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/TermsandCondition"
                android:textColor="#0884F9"
                android:textSize="@dimen/_9sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/txtPrivacy"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtPrivacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/_10sdp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/PrivacyPolicy"
                android:textColor="#0884F9"
                android:textSize="@dimen/_9sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/txtTerms"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>