                    android:textSize="@dimen/_12sdp"
                    app:layout_constraintBottom_toBottomOf="@+id/ic_last_progres"
                    app:layout_constraintStart_toEndOf="@+id/ic_last_progres"
                    app:layout_constraintTop_toTopOf="@+id/ic_last_progres"
                    app:layout_constraintVertical_chainStyle="packed">

                </com.google.android.material.textview.MaterialTextView>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/textView42last"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:includeFontPadding="false"
                    android:text="Share location"
                    android:textColor="#773C4B5D"
                    android:textSize="@dimen/_11sdp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/textView41last"
                    app:layout_constraintTop_toBottomOf="@+id/textView41last">

                </com.google.android.material.textview.MaterialTextView>




            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
