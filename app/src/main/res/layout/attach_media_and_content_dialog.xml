                    android:textSize="@dimen/_11sdp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/textView41lastrecord_audio_attachment"
                    app:layout_constraintTop_toBottomOf="@+id/textView41lastrecord_audio_attachment">

                </com.google.android.material.textview.MaterialTextView>



            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/file_attachment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/record_audio_attachment">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/file_attachment_btn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
