                    app:layout_constraintBottom_toBottomOf="@+id/ic_schedule"
                    app:layout_constraintStart_toEndOf="@+id/ic_schedule"
                    app:layout_constraintTop_toTopOf="@+id/ic_schedule"
                    app:layout_constraintVertical_chainStyle="packed">

                </com.google.android.material.textview.MaterialTextView>

                <ImageView
                    android:id="@+id/swipe_con_premium"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:src="@drawable/ic_message_premium_btn"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/textView41schedule"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintStart_toEndOf="@+id/textView41schedule"
                    app:layout_constraintTop_toTopOf="@+id/textView41schedule"
                    app:layout_constraintWidth_percent="0.08"
                    tools:visibility="gone">

                </ImageView>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/textView42schedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:includeFontPadding="false"
                    android:text="Arrange a schedule message"
                    android:textColor="#773C4B5D"
                    android:textSize="@dimen/_11sdp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/textView41schedule"
                    app:layout_constraintTop_toBottomOf="@+id/textView41schedule">

                </com.google.android.material.textview.MaterialTextView>




            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
