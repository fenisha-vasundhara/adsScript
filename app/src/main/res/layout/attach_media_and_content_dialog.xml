        <com.google.android.material.button.MaterialButton
            android:id="@+id/imageView18"
            style="@style/Widget.App.IconCloseButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/home_material_ic_close_rounded"
            app:icon="@drawable/home_material_ic_close_rounded"
            app:iconGravity="textStart"
            android:layout_marginTop="@dimen/_5sdp"
            app:iconPadding="0dp"
            app:iconTint="@{isblacktheme ? @color/white : @color/black2}"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.06">

        </com.google.android.material.button.MaterialButton>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_bold"
            android:includeFontPadding="false"
            android:text="@string/content_and_tools"
            android:textColor="@{isblacktheme ? @color/white : @color/black2}"
            android:textSize="@dimen/_15sdp"
            app:layout_constraintBottom_toBottomOf="@+id/imageView18"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/imageView18">

        </com.google.android.material.textview.MaterialTextView>

        <View
            android:id="@+id/view22"
            android:layout_width="0dp"
            android:layout_height="@dimen/_1sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:background="@{isblacktheme ? @color/attachmnet_dialog_theme_dark : @color/attachmnet_dialog_theme_light}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/content">


        </View>



        <androidx.constraintlayout.widget.ConstraintLayout
