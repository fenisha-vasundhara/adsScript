                </com.google.android.material.button.MaterialButton>


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/textView41lastimage_attachment"
                    fullappfontstyleregular="@{0}"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_15sdp"
                    android:includeFontPadding="false"
                    android:text="@string/Gallery"
                    android:textColor="@{isblacktheme ? @color/white : @color/black2}"
                    android:textSize="@dimen/_12sdp"
                    app:layout_constraintBottom_toBottomOf="@+id/ic_last_image_attachment"
                    app:layout_constraintStart_toEndOf="@+id/ic_last_image_attachment"
                    app:layout_constraintTop_toTopOf="@+id/ic_last_image_attachment"
